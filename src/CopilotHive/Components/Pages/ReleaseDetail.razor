@page "/releases/{ReleaseId}"
@using CopilotHive.Dashboard
@using CopilotHive.Goals
@using Markdig
@inject IGoalStore GoalStore
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HttpClient HttpClient
@inject CopilotHive.Configuration.HiveConfigFile? HiveConfig
@inject PageHeaderState PageHeader
@using CopilotHive.Services
@using System.Text.Json
@using System.Text
@using System.Net

@if (_release is not null)
{
    <!-- Header -->
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
        @foreach (var repo in _release.RepositoryNames)
        {
            <span class="repo-tag">@repo</span>
        }
        <span class="badge @ReleaseBadge(_release.Status)">@_release.Status</span>
        @if (_release.Status == ReleaseStatus.Planning)
        {
            <button class="approve-btn" @onclick="ValidateReleaseAsync" disabled="@_isValidating">
                @(_isValidating ? "Validating..." : "Validate")
            </button>
            <button class="approve-btn" @onclick="MarkAsReleased" disabled="@(!_isValid || _isReleasing)">
                ✅ Mark as Released
            </button>
            @if (!_isValid && _validationErrors.Count == 0 && !_isValidating && !_isReleasing)
            {
                <span style="color:var(--text-muted);font-size:0.8rem">↑ Click Validate first</span>
            }
            @if (_isReleasing)
            {
                <span style="color:var(--text-muted);font-size:0.85rem">Releasing...</span>
            }
        }
        else if (_release.Status == ReleaseStatus.Released)
        {
            <button class="danger-btn" disabled title="Cannot unrelease — git operations are irreversible">
                🔒 Unrelease
            </button>
            <span style="color:var(--text-muted);font-size:0.8rem">Git operations cannot be undone</span>
        }
    </div>

    @if (_validationErrors.Count > 0)
    {
        <div class="card" style="margin-top:0.5rem;border-color:var(--red)">
            <h3 style="color:var(--red)">Validation Issues</h3>
            <ul style="margin:0.5rem 0 0 0;padding-left:1.5rem">
                @foreach (var err in _validationErrors)
                {
                    <li>@err</li>
                }
            </ul>
        </div>
    }

    @if (_isValid && _validationErrors.Count == 0)
    {
        <div class="card" style="margin-top:0.5rem;border-color:var(--green)">
            <span style="color:var(--green)">✅ Validation passed — ready to release</span>
        </div>
    }

    @if (_releaseResult is not null)
    {
        <div class="card" style="margin-top:1rem">
            <h3>Release Results</h3>
            <table style="width:100%;font-size:0.85rem;border-collapse:collapse">
                <thead>
                    <tr style="text-align:left;border-bottom:1px solid var(--border)">
                        <th style="padding:0.4rem">Repository</th>
                        <th style="padding:0.4rem">Status</th>
                        <th style="padding:0.4rem">Merged To</th>
                        <th style="padding:0.4rem">Merge SHA</th>
                        <th style="padding:0.4rem">Tag Branch</th>
                        <th style="padding:0.4rem">Tag Created</th>
                        <th style="padding:0.4rem">Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _releaseResult.Results)
                    {
                        <tr style="border-bottom:1px solid var(--border)">
                            <td style="padding:0.4rem">@r.RepoName</td>
                            <td style="padding:0.4rem">
                                @if (r.Skipped) { <span style="color:var(--text-muted)">Skipped</span> }
                                else if (r.Success) { <span style="color:var(--green)">✓ Success</span> }
                                else { <span style="color:var(--red)">✗ Failed</span> }
                            </td>
                            <td style="padding:0.4rem">@(r.MergedTo ?? "—")</td>
                            <td style="padding:0.4rem;font-family:monospace;font-size:0.8rem">@(r.MergeSha?[..Math.Min(7, r.MergeSha.Length)] ?? "—")</td>
                            <td style="padding:0.4rem">@(r.TaggedBranch ?? "—")</td>
                            <td style="padding:0.4rem">@(r.TagCreated ? "✓" : "—")</td>
                            <td style="padding:0.4rem;color:var(--red)">@(r.Error ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_releaseError is not null)
    {
        <div class="card" style="margin-top:1rem;border-color:var(--red)">
            <h3 style="color:var(--red)">⚠️ Release Failed</h3>
            <p>@_releaseError</p>
            @if (_executionFailed)
            {
                <p style="color:var(--text-muted);font-size:0.85rem">
                    Tags created for previous repositories have been rolled back (attempted). Merges are NOT reverted.
                    The release remains in Planning status.
                </p>
            }
        </div>
    }

    <!-- Edit controls (Planning only) -->
    @if (_release.Status == ReleaseStatus.Planning)
    {
        <!-- Tag editor -->
        <div class="card" style="margin-bottom:1rem">
            <div class="label" style="margin-bottom:0.5rem">Tag</div>
            <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                <input type="text" @bind="_editTag" style="flex:1;min-width:12rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;padding:0.4rem 0.6rem" placeholder="e.g. v1.2.0" />
                <button class="approve-btn" @onclick="SaveTag">Save Tag</button>
                @if (!string.IsNullOrEmpty(_tagError))
                {
                    <span class="error-msg">@_tagError</span>
                }
                @if (_tagSaved)
                {
                    <span style="color:var(--green);font-size:0.85rem">✓ Saved</span>
                }
            </div>
        </div>

        <!-- Repositories editor -->
        <div class="card" style="margin-bottom:1rem">
            <div class="label" style="margin-bottom:0.5rem">Repositories</div>
            <div style="display:flex;flex-direction:column;gap:0.4rem;margin-bottom:0.5rem">
                @foreach (var repo in _configuredRepoNames)
                {
                    <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer">
                        <input type="checkbox"
                               checked="@_selectedRepos.Contains(repo)"
                               @onchange="@(e => ToggleRepo(repo, (bool)(e.Value ?? false)))" />
                        <span>@repo</span>
                    </label>
                }
            </div>
            <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                <button class="approve-btn" @onclick="SaveRepositories">Save Repositories</button>
                @if (!string.IsNullOrEmpty(_repositoriesError))
                {
                    <span class="error-msg">@_repositoriesError</span>
                }
                @if (_repositoriesSaved)
                {
                    <span style="color:var(--green);font-size:0.85rem">✓ Saved</span>
                }
            </div>
        </div>
    }

    <!-- Metadata card -->
    <div class="card" style="margin-bottom:1rem;font-size:0.85rem;color:var(--text-muted)">
        <div style="display:flex;gap:1.5rem;flex-wrap:wrap">
            <span>Created: <strong style="color:var(--text)">@_release.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong> UTC</span>
            @if (_release.ReleasedAt.HasValue)
            {
                <span>Released: <strong style="color:var(--text)">@_release.ReleasedAt.Value.ToString("yyyy-MM-dd HH:mm")</strong> UTC</span>
            }
            <span>Goals: <strong style="color:var(--text)">@_goals.Count</strong></span>
        </div>
    </div>

    <!-- Editable Notes (Planning only) -->
    @if (_release.Status == ReleaseStatus.Planning)
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label" style="margin-bottom:0.5rem">Notes</div>
            <textarea @bind="_editNotes" rows="4"
                      style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;padding:0.5rem;font-family:inherit;resize:vertical"
                      placeholder="Release notes…"></textarea>
            <div style="margin-top:0.5rem;display:flex;gap:0.5rem">
                <button class="approve-btn" @onclick="SaveNotes">Save Notes</button>
                @if (!string.IsNullOrEmpty(_notesError))
                {
                    <span class="error-msg">@_notesError</span>
                }
                @if (_notesSaved)
                {
                    <span style="color:var(--green);font-size:0.85rem">✓ Saved</span>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_release.Notes))
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label" style="margin-bottom:0.5rem">Notes</div>
            <div class="chat-msg-content">@((MarkupString)RenderMarkdown(_release.Notes))</div>
        </div>
    }

    <!-- Goals grouped by scope -->
    @if (_goals.Count > 0)
    {
        var breaking = _goals.Where(g => g.Scope == GoalScope.Breaking).ToList();
        var features = _goals.Where(g => g.Scope == GoalScope.Feature).ToList();
        var patches = _goals.Where(g => g.Scope == GoalScope.Patch).ToList();

        <h2 style="margin-top:1rem;margin-bottom:0.75rem">Goals</h2>

        @if (breaking.Count > 0)
        {
            <div class="release-scope-section">
                <div class="release-scope-header">💥 Breaking Changes</div>
                @foreach (var g in breaking)
                {
                    <div class="release-goal-row">
                        <a href="/goals/@g.Id" class="goal-link">@g.Id</a>
                        <span class="goal-desc" style="flex:1">@Truncate(g.Description, 120)</span>
                        <span class="badge @StatusBadge(g.Status)">@g.Status</span>
                    </div>
                }
            </div>
        }

        @if (features.Count > 0)
        {
            <div class="release-scope-section">
                <div class="release-scope-header">✨ Features</div>
                @foreach (var g in features)
                {
                    <div class="release-goal-row">
                        <a href="/goals/@g.Id" class="goal-link">@g.Id</a>
                        <span class="goal-desc" style="flex:1">@Truncate(g.Description, 120)</span>
                        <span class="badge @StatusBadge(g.Status)">@g.Status</span>
                    </div>
                }
            </div>
        }

        @if (patches.Count > 0)
        {
            <div class="release-scope-section">
                <div class="release-scope-header">🔧 Fixes</div>
                @foreach (var g in patches)
                {
                    <div class="release-goal-row">
                        <a href="/goals/@g.Id" class="goal-link">@g.Id</a>
                        <span class="goal-desc" style="flex:1">@Truncate(g.Description, 120)</span>
                        <span class="badge @StatusBadge(g.Status)">@g.Status</span>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <p style="color:var(--text-muted);margin-top:0.5rem">No goals assigned to this release yet.</p>
    }

    <!-- Changelog preview -->
    <h2 style="margin-top:1.5rem;margin-bottom:0.5rem">Changelog Preview</h2>
    <div style="display:flex;gap:0.5rem;margin-bottom:0.5rem">
        <button class="chat-action-btn" @onclick="CopyChangelog">📋 Copy Changelog</button>
    </div>
    <details class="collapsible-output" open>
        <summary>Markdown Changelog</summary>
        <div class="changelog-preview">
            <pre>@BuildChangelog()</pre>
        </div>
    </details>
}
else if (_loaded)
{
    <p style="color:var(--text-muted)">Release not found.</p>
}

@code {
    [Parameter] public string ReleaseId { get; set; } = "";

    private Release? _release;
    private List<Goal> _goals = [];
    private bool _loaded;
    private string _editNotes = "";
    private bool _notesSaved;
    private string? _notesError;

    // Release validation / execution state
    private bool _isValid;
    private bool _isValidating;
    private List<string> _validationErrors = [];
    private ReleaseExecutionResult? _releaseResult;
    private string? _releaseError;
    private bool _isReleasing;
    private bool _executionFailed; // set only for 500 execution failures
    private static readonly JsonSerializerOptions JsonOpts = new(JsonSerializerDefaults.Web);

    // Tag edit state
    private string _editTag = "";
    private bool _tagSaved;
    private string? _tagError;

    // Repositories edit state
    private HashSet<string> _selectedRepos = new(StringComparer.OrdinalIgnoreCase);
    private bool _repositoriesSaved;
    private string? _repositoriesError;

    protected override async Task OnInitializedAsync()
    {
        var decoded = Uri.UnescapeDataString(ReleaseId);
        _release = await GoalStore.GetReleaseAsync(decoded);
        if (_release is not null)
        {
            PageHeader.SetTitle($"📦 {_release.Tag}");
            PageHeader.SetBack("/releases");
            _editNotes = _release.Notes ?? "";
            _editTag = _release.Tag;
            _selectedRepos = new HashSet<string>(_release.RepositoryNames, StringComparer.OrdinalIgnoreCase);
            _goals = (await GoalStore.GetGoalsByReleaseAsync(decoded)).ToList();
        }
        if (_release is null)
        {
            PageHeader.SetTitle("Release Not Found");
            PageHeader.SetBack("/releases");
        }
        _loaded = true;
    }

    private async Task ValidateReleaseAsync()
    {
        _isValidating = true;
        _isValid = false;
        _validationErrors = [];
        _releaseError = null;
        try
        {
            var id = Uri.EscapeDataString(_release!.Id);
            var response = await HttpClient.GetAsync($"/api/releases/{id}/validate");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                _isValid = doc.RootElement.GetProperty("valid").GetBoolean();
                _validationErrors = doc.RootElement.GetProperty("errors")
                    .EnumerateArray()
                    .Select(e => e.GetString() ?? "")
                    .ToList();
            }
            else
            {
                _isValid = false;
                _validationErrors = ["Validation request failed."];
            }
        }
        catch
        {
            _isValid = false;
            _validationErrors = ["Validation request failed."];
        }
        finally
        {
            _isValidating = false;
        }
    }

    private async Task MarkAsReleased()
    {
        _isReleasing = true;
        _releaseError = null;
        _releaseResult = null;
        _executionFailed = false;
        _validationErrors = [];
        try
        {
            var id = Uri.EscapeDataString(_release!.Id);
            var body = new StringContent(JsonSerializer.Serialize(new { status = "Released" }), Encoding.UTF8, "application/json");
            var response = await HttpClient.PatchAsync($"/api/releases/{id}/status", body);
            var json = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                using var doc = JsonDocument.Parse(json);
                if (doc.RootElement.TryGetProperty("release", out var releaseEl))
                    _release = JsonSerializer.Deserialize<Release>(releaseEl.GetRawText(), JsonOpts);
                if (doc.RootElement.TryGetProperty("result", out var resultEl))
                    _releaseResult = JsonSerializer.Deserialize<ReleaseExecutionResult>(resultEl.GetRawText(), JsonOpts);
            }
            else if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                using var doc = JsonDocument.Parse(json);
                _validationErrors = doc.RootElement.GetProperty("errors").EnumerateArray().Select(e => e.GetString() ?? "").ToList();
                _isValid = false;
            }
            else if (response.StatusCode == HttpStatusCode.Conflict)
            {
                using var doc = JsonDocument.Parse(json);
                _releaseError = doc.RootElement.GetProperty("error").GetString();
            }
            else
            {
                // 500/503 ProblemDetails
                using var doc = JsonDocument.Parse(json);
                _releaseError = doc.RootElement.TryGetProperty("detail", out var d) ? d.GetString() : "Release failed.";
                _executionFailed = response.StatusCode == HttpStatusCode.InternalServerError;
            }
        }
        catch (Exception ex) { _releaseError = ex.Message; }
        finally { _isReleasing = false; }
    }

    private async Task SaveNotes()
    {
        _notesError = null;
        _notesSaved = false;
        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { notes = _editNotes }),
            System.Text.Encoding.UTF8,
            "application/json");
        var id = Uri.EscapeDataString(ReleaseId);
        var response = await HttpClient.PatchAsync($"/api/releases/{id}/notes", body);
        if (response.IsSuccessStatusCode)
        {
            _release!.Notes = _editNotes;
            _notesSaved = true;
            _isValid = false;
            _validationErrors = [];
            StateHasChanged();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            _notesError = $"Error {(int)response.StatusCode}: {error}";
        }
    }

    private async Task SaveTag()
    {
        _tagError = null;
        _tagSaved = false;
        if (string.IsNullOrWhiteSpace(_editTag))
        {
            _tagError = "Tag cannot be empty.";
            return;
        }
        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { tag = _editTag.Trim() }),
            System.Text.Encoding.UTF8,
            "application/json");
        var id = Uri.EscapeDataString(ReleaseId);
        var response = await HttpClient.PatchAsync($"/api/releases/{id}/tag", body);
        if (response.IsSuccessStatusCode)
        {
            _release!.Tag = _editTag.Trim();
            _tagSaved = true;
            _isValid = false;
            _validationErrors = [];
            PageHeader.SetTitle($"📦 {_release.Tag}");
            PageHeader.SetBack("/releases");
            StateHasChanged();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            _tagError = $"Error {(int)response.StatusCode}: {error}";
        }
    }

    /// <summary>
    /// Combined list of repository names from config plus any orphaned repos
    /// that are in the release but not in the current HiveConfig.
    /// </summary>
    private IEnumerable<string> _configuredRepoNames =>
        (HiveConfig?.Repositories.Select(r => r.Name) ?? [])
            .Union(_release?.RepositoryNames.Where(r =>
                HiveConfig?.Repositories.All(c => !c.Name.Equals(r, StringComparison.OrdinalIgnoreCase)) ?? true) ?? [],
                StringComparer.OrdinalIgnoreCase);

    private void ToggleRepo(string repo, bool selected)
    {
        if (selected)
            _selectedRepos.Add(repo);
        else
            _selectedRepos.Remove(repo);
    }

    private async Task SaveRepositories()
    {
        _repositoriesError = null;
        _repositoriesSaved = false;
        var repos = _selectedRepos.ToList();
        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { repositories = repos }),
            System.Text.Encoding.UTF8,
            "application/json");
        var id = Uri.EscapeDataString(ReleaseId);
        var response = await HttpClient.PatchAsync($"/api/releases/{id}/repositories", body);
        if (response.IsSuccessStatusCode)
        {
            _release!.RepositoryNames.Clear();
            _release.RepositoryNames.AddRange(repos);
            _repositoriesSaved = true;
            _isValid = false;
            _validationErrors = [];
            StateHasChanged();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            _repositoriesError = $"Error {(int)response.StatusCode}: {error}";
        }
    }

    private async Task CopyChangelog()
    {
        var changelog = BuildChangelog();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", changelog);
    }

    private string BuildChangelog()
    {
        if (_release is null) return "";

        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"## {_release.Tag}");
        sb.AppendLine();

        if (_release.ReleasedAt.HasValue)
            sb.AppendLine($"_Released {_release.ReleasedAt.Value:yyyy-MM-dd}_");
        else
            sb.AppendLine($"_Created {_release.CreatedAt:yyyy-MM-dd} · Status: {_release.Status}_");
        sb.AppendLine();

        var breaking = _goals.Where(g => g.Scope == GoalScope.Breaking).ToList();
        var features = _goals.Where(g => g.Scope == GoalScope.Feature).ToList();
        var patches = _goals.Where(g => g.Scope == GoalScope.Patch).ToList();

        if (breaking.Count > 0)
        {
            sb.AppendLine("### 💥 Breaking Changes");
            sb.AppendLine();
            foreach (var g in breaking)
                sb.AppendLine($"- {g.Description}");
            sb.AppendLine();
        }

        if (features.Count > 0)
        {
            sb.AppendLine("### ✨ Features");
            sb.AppendLine();
            foreach (var g in features)
                sb.AppendLine($"- {g.Description}");
            sb.AppendLine();
        }

        if (patches.Count > 0)
        {
            sb.AppendLine("### 🔧 Fixes");
            sb.AppendLine();
            foreach (var g in patches)
                sb.AppendLine($"- {g.Description}");
            sb.AppendLine();
        }

        if (!string.IsNullOrEmpty(_release.Notes))
        {
            sb.AppendLine("### Notes");
            sb.AppendLine();
            sb.AppendLine(_release.Notes);
        }

        return sb.ToString().TrimEnd();
    }

    private static string ReleaseBadge(ReleaseStatus s) => s switch
    {
        ReleaseStatus.Planning => "badge-yellow",
        ReleaseStatus.Released => "badge-green",
        _ => "badge-muted",
    };

    private static string StatusBadge(GoalStatus s) => s switch
    {
        GoalStatus.Completed => "badge-green",
        GoalStatus.Failed => "badge-red",
        GoalStatus.InProgress => "badge-blue",
        GoalStatus.Pending => "badge-yellow",
        GoalStatus.Cancelled => "badge-muted",
        _ => "badge-muted",
    };

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static readonly MarkdownPipeline MdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static string RenderMarkdown(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return Markdown.ToHtml(content, MdPipeline);
    }
}
