@page "/orchestrator"
@using CopilotHive.Dashboard
@using CopilotHive.Goals
@using CopilotHive.Orchestration
@implements IDisposable
@inject DashboardStateService State
@inject IJSRuntime JS
@inject IGoalStore GoalStore
@inject PageHeaderState PageHeader

<div class="cards">
    <div class="card">
        <div class="label">Uptime</div>
        <div class="value" style="font-size:1rem">@FormatUptime(_info.Uptime)</div>
    </div>
    <div class="card">
        <div class="label">Version</div>
        <div class="value" style="font-size:1rem">@_info.Version</div>
    </div>
    <div class="card">
        <div class="label">SharpCoder</div>
        <div class="value" style="font-size:1rem">@(_info.SharpCoderVersion ?? "—")</div>
    </div>
    <div class="card">
        <div class="label">Server Time</div>
        <div class="value" style="font-size:1rem">@_info.ServerTime.ToString("HH:mm:ss") UTC</div>
    </div>
</div>

<h2 style="margin-top:1.5rem">Model Configuration</h2>
<table>
    <thead>
        <tr><th>Role</th><th>Model</th><th>Reasoning</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><span class="badge badge-yellow">brain</span></td>
            <td style="font-family:monospace;font-size:0.85rem">@StripReasoning(_info.BrainModel)</td>
            <td>@ReasoningBadge(_info.BrainModel)</td>
        </tr>
        <tr>
            <td><span class="badge badge-yellow">composer</span></td>
            <td style="font-family:monospace;font-size:0.85rem">@StripReasoning(_info.ComposerModel)</td>
            <td>@ReasoningBadge(_info.ComposerModel)</td>
        </tr>
        @foreach (var (role, model) in _info.RoleModels)
        {
            <tr>
                <td><span class="badge badge-blue">@role</span></td>
                <td style="font-family:monospace;font-size:0.85rem">@StripReasoning(model)</td>
                <td>@ReasoningBadge(model)</td>
            </tr>
        }
        <tr>
            <td><span class="badge badge-green">compaction</span></td>
            <td style="font-family:monospace;font-size:0.85rem">@(string.IsNullOrEmpty(_info.CompactionModel) ? "(use main model)" : StripReasoning(_info.CompactionModel))</td>
            <td>@(string.IsNullOrEmpty(_info.CompactionModel) ? "—" : ReasoningBadge(_info.CompactionModel))</td>
        </tr>
    </tbody>
</table>

<h2 style="margin-top:1.5rem">Brain</h2>
@if (_stats is not null)
{
    <div class="cards">
        <div class="card">
            <div class="label">Context</div>
            <div class="value" style="color:@ContextColor">@FormatTokens(_stats.ContextTokens)</div>
            <div style="font-size:0.75rem;color:var(--text-muted)">
                @_stats.ContextUsagePercent% of @FormatTokens(_stats.MaxContextTokens)
            </div>
        </div>
        <div class="card">
            <div class="label">Messages</div>
            <div class="value">@_stats.MessageCount</div>
        </div>
        <div class="card">
            <div class="label">Max Steps</div>
            <div class="value">@_stats.MaxSteps</div>
        </div>
    </div>

    <div class="cards" style="margin-top:0.5rem">
        <div class="card">
            <div class="label">Cumulative Input</div>
            <div class="value" style="font-size:1rem">@FormatTokens(_stats.CumulativeInputTokens)</div>
        </div>
        <div class="card">
            <div class="label">Cumulative Output</div>
            <div class="value" style="font-size:1rem">@FormatTokens(_stats.CumulativeOutputTokens)</div>
        </div>
    </div>

    <div style="margin-top:1rem;background:var(--surface);border-radius:8px;padding:0.75rem 1rem">
        <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.25rem">Context Usage</div>
        <div style="background:var(--bg);border-radius:4px;height:1.25rem;overflow:hidden">
            <div style="width:@(_stats.ContextUsagePercent)%;height:100%;background:@ContextColor;transition:width 0.3s"></div>
        </div>
    </div>

    <div style="margin-top:1rem">
        <button class="chat-action-btn chat-action-btn--danger" disabled="@_resettingBrain" @onclick="ResetBrainSessionAsync">
            @(_resettingBrain ? "⏳ Resetting…" : "🔄 Reset Brain Session")
        </button>
    </div>
}
else
{
    <p style="color:var(--text-muted)">Brain not connected.</p>
}

<h2 style="margin-top:1.5rem">Composer</h2>
@if (_composerStats is not null)
{
    <div class="cards">
        <div class="card">
            <div class="label">Context</div>
            <div class="value" style="color:@ComposerContextColor">@FormatTokens(_composerStats.ContextTokens)</div>
            <div style="font-size:0.75rem;color:var(--text-muted)">
                @_composerStats.ContextUsagePercent% of @FormatTokens(_composerStats.MaxContextTokens)
            </div>
        </div>
        <div class="card">
            <div class="label">Messages</div>
            <div class="value">@_composerStats.MessageCount</div>
        </div>
        <div class="card">
            <div class="label">Max Steps</div>
            <div class="value">@_composerStats.MaxSteps</div>
        </div>
    </div>

    <div class="cards" style="margin-top:0.5rem">
        <div class="card">
            <div class="label">Cumulative Input</div>
            <div class="value" style="font-size:1rem">@FormatTokens(_composerStats.CumulativeInputTokens)</div>
        </div>
        <div class="card">
            <div class="label">Cumulative Output</div>
            <div class="value" style="font-size:1rem">@FormatTokens(_composerStats.CumulativeOutputTokens)</div>
        </div>
    </div>

    <div style="margin-top:1rem;background:var(--surface);border-radius:8px;padding:0.75rem 1rem">
        <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.25rem">Context Usage</div>
        <div style="background:var(--bg);border-radius:4px;height:1.25rem;overflow:hidden">
            <div style="width:@(_composerStats.ContextUsagePercent)%;height:100%;background:@ComposerContextColor;transition:width 0.3s"></div>
        </div>
    </div>
}
else
{
    <p style="color:var(--text-muted)">Composer not connected.</p>
}

<h2 style="margin-top:1.5rem">Clarifications</h2>

<div class="cards" style="margin-bottom:1rem">
    <div class="card">
        <div class="label">Total</div>
        <div class="value">@_clarifications.Count</div>
    </div>
    <div class="card">
        <div class="label">Brain</div>
        <div class="value" style="color:var(--accent)">@_clarifications.Count(c => string.Equals(c.Clarification.AnsweredBy, "brain", StringComparison.OrdinalIgnoreCase))</div>
    </div>
    <div class="card">
        <div class="label">Composer</div>
        <div class="value" style="color:var(--yellow)">@_clarifications.Count(c => string.Equals(c.Clarification.AnsweredBy, "composer", StringComparison.OrdinalIgnoreCase))</div>
    </div>
    <div class="card">
        <div class="label">Human</div>
        <div class="value" style="color:var(--green)">@_clarifications.Count(c => string.Equals(c.Clarification.AnsweredBy, "human", StringComparison.OrdinalIgnoreCase))</div>
    </div>
    <div class="card">
        <div class="label">Timeout</div>
        <div class="value" style="color:var(--red)">@_clarifications.Count(c => string.Equals(c.Clarification.AnsweredBy, "timeout", StringComparison.OrdinalIgnoreCase))</div>
    </div>
</div>

@if (_clarifications.Count == 0)
{
    <p style="color:var(--text-muted)">No clarifications recorded yet.</p>
}
else
{
    <div style="overflow-x:auto">
        <table>
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Goal</th>
                    <th>Phase</th>
                    <th>Question</th>
                    <th>Answered By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (goalId, clarif) in _clarifications.Take(10))
                {
                    <tr>
                        <td style="white-space:nowrap;font-size:0.8rem;color:var(--text-muted)">
                            @clarif.Timestamp.ToString("yyyy-MM-dd HH:mm")
                        </td>
                        <td style="font-size:0.85rem">
                            <a href="/goals/@goalId" style="color:var(--accent);text-decoration:none">@goalId</a>
                        </td>
                        <td style="font-size:0.85rem">@clarif.Phase</td>
                        <td style="font-size:0.85rem;max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                            title="@clarif.Question">
                            @(clarif.Question.Length > 80 ? clarif.Question[..80] + "…" : clarif.Question)
                        </td>
                        <td>
                            <span class="badge @AnsweredByBadgeClass(clarif.AnsweredBy)">@clarif.AnsweredBy</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private BrainStats? _stats;
    private BrainStats? _composerStats;
    private OrchestratorInfo _info = new();
    private bool _resettingBrain;
    private IReadOnlyList<(string GoalId, PersistedClarification Clarification)> _clarifications = [];

    protected override async Task OnInitializedAsync()
    {
        PageHeader.SetTitle("🎵 Orchestrator");
        Refresh();
        State.OnStateChanged += RefreshState;
        await LoadClarificationsAsync();
    }

    private async Task LoadClarificationsAsync()
    {
        _clarifications = await GoalStore.GetAllClarificationsAsync();
    }

    private void Refresh()
    {
        _stats = State.GetBrainStats();
        _composerStats = State.GetComposerStats();
        _info = State.GetOrchestratorInfo();
    }

    private void RefreshState() => InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private string ContextColor => _stats?.ContextUsagePercent switch
    {
        >= 80 => "var(--red)",
        >= 50 => "var(--accent)",
        _ => "var(--green)",
    };

    private string ComposerContextColor => _composerStats?.ContextUsagePercent switch
    {
        >= 80 => "var(--red)",
        >= 50 => "var(--accent)",
        _ => "var(--green)",
    };

    private static string FormatTokens(long tokens) => tokens switch
    {
        >= 1_000_000 => $"{tokens / 1_000_000.0:F1}M",
        >= 1_000 => $"{tokens / 1_000.0:F1}k",
        _ => tokens.ToString(),
    };

    private static string FormatTokens(int tokens) => FormatTokens((long)tokens);

    private static string FormatUptime(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s"
        : $"{ts.Minutes}m {ts.Seconds}s";

    private static readonly HashSet<string> KnownReasoningLevels = new(StringComparer.OrdinalIgnoreCase)
        { "none", "low", "medium", "high", "extra_high" };

    private static string StripReasoning(string model)
    {
        var lastColon = model.LastIndexOf(':');
        if (lastColon <= 0 || lastColon == model.Length - 1) return model;
        var suffix = model[(lastColon + 1)..];
        return KnownReasoningLevels.Contains(suffix) ? model[..lastColon] : model;
    }

    private static RenderFragment ReasoningBadge(string model) => builder =>
    {
        var lastColon = model.LastIndexOf(':');
        if (lastColon <= 0 || lastColon == model.Length - 1) return;
        var suffix = model[(lastColon + 1)..];
        if (!KnownReasoningLevels.Contains(suffix)) return;

        var color = suffix.ToLowerInvariant() switch
        {
            "extra_high" => "var(--red)",
            "high" => "var(--accent)",
            "medium" => "var(--green)",
            "low" => "var(--text-muted)",
            _ => "var(--text-muted)",
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "badge");
        builder.AddAttribute(2, "style", $"background:{color};color:#fff;font-size:0.7rem");
        builder.AddContent(3, suffix);
        builder.CloseElement();
    };

    public void Dispose() => State.OnStateChanged -= RefreshState;

    private static string AnsweredByBadgeClass(string answeredBy) => answeredBy.ToLowerInvariant() switch
    {
        "brain" => "badge-blue",
        "composer" => "badge-yellow",
        "human" => "badge-green",
        "timeout" => "badge-red",
        _ => "badge-muted",
    };

    private async Task ResetBrainSessionAsync()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "Are you sure you want to reset the Brain session? This will clear all conversation history and start a fresh session. The system prompt will be rebuilt with the current orchestrator.agents.md content reloaded from disk.");
        if (!confirmed)
            return;

        _resettingBrain = true;
        StateHasChanged();
        try
        {
            await State.ResetBrainSessionAsync();
            Refresh();
        }
        finally
        {
            _resettingBrain = false;
            StateHasChanged();
        }
    }
}
