@page "/configuration"
@using CopilotHive.Configuration
@using CopilotHive.Dashboard
@using Markdig
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject ConfigRepoManager ConfigRepo
@inject PageHeaderState PageHeader
@inject HttpClient HttpClient

<p style="color:var(--text-muted);margin-bottom:1.5rem">
    Config repo: <code style="font-size:0.85rem">@ConfigRepo.LocalPath</code>
</p>

@if (_loading)
{
    <p style="color:var(--text-muted)">Loading configuration files…</p>
}
else if (_error is not null)
{
    <p style="color:var(--red)">Error loading configuration: @_error</p>
}
else
{
    <div class="config-tabs">
        @foreach (var tab in _tabs)
        {
            <button class="config-tab @(tab == _activeTab ? "active" : "")"
                    @onclick="() => _activeTab = tab">@tab</button>
        }
    </div>

    <div class="config-content">
        @if (_activeTab == ModelsTabName)
        {
            @if (_modelsLoading)
            {
                <p style="color:var(--text-muted)">Loading model configuration…</p>
            }
            else if (_modelsData?.AvailableModels is null || _modelsData.AvailableModels.Count == 0)
            {
                <p style="color:var(--text-muted);font-style:italic">
                    Configure <code>models.available_models</code> in <code>hive-config.yaml</code> to enable model selection.
                </p>
            }
            else
            {
                var models = _modelsData.AvailableModels;

                <div style="display:grid;grid-template-columns:14rem 1fr;gap:0.75rem 1rem;align-items:center;max-width:600px">

                    <label style="color:var(--text-muted);font-size:0.9rem">Orchestrator / Brain</label>
                    <select @bind="_orchestratorModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Composer</label>
                    <select @bind="_composerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Coder</label>
                    <select @bind="_coderModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Tester</label>
                    <select @bind="_testerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Reviewer</label>
                    <select @bind="_reviewerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Doc Writer</label>
                    <select @bind="_docwriterModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Improver</label>
                    <select @bind="_improverModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Compaction model</label>
                    <select @bind="_compactionModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(use main model)</option>
                        @foreach (var m in models)
                        {
                            <option value="@m.Name">@m.Name</option>
                        }
                    </select>

                </div>

                <div style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem">
                    <button class="approve-btn" disabled="@_modelsSaving" @onclick="SaveModelsAsync">
                        @(_modelsSaving ? "Saving…" : "💾 Save")
                    </button>
                    @if (_saveSuccess)
                    {
                        <span style="color:var(--accent);font-size:0.9rem">✅ Saved successfully</span>
                    }
                    @if (_saveError is not null)
                    {
                        <span style="color:var(--red);font-size:0.9rem">@_saveError</span>
                    }
                </div>
            }
        }
        else if (ActiveTab?.EndsWith(".md") == true)
        {
            <div class="config-markdown">
                @((MarkupString)RenderMarkdown(GetActiveContent() ?? ""))
            </div>
        }
        else if (ActiveTab?.Contains("hive-config.yaml") == true)
        {
            <pre class="yaml-highlighted"><code>@((MarkupString)HighlightYaml(GetActiveContent() ?? ""))</code></pre>
        }
        else
        {
            <pre><code>@GetActiveContent()</code></pre>
        }
    </div>
}

@code {
    private const string ModelsTabName = "Models";

    private sealed record ModelConfigResponse(
        [property: JsonPropertyName("orchestrator")]    string? Orchestrator,
        [property: JsonPropertyName("composer")]        string? Composer,
        [property: JsonPropertyName("compaction")]      string? Compaction,
        [property: JsonPropertyName("workers")]         Dictionary<string, WorkerConfigDto>? Workers,
        [property: JsonPropertyName("availableModels")] List<ModelEntryDto>? AvailableModels);

    private sealed record WorkerConfigDto(
        [property: JsonPropertyName("model")] string? Model);

    private sealed record ModelEntryDto(
        [property: JsonPropertyName("name")] string Name);

    private bool _loading = true;
    private string? _error;
    private string _activeTab = ModelsTabName;
    private readonly Dictionary<string, string> _files = [];
    private List<string> _tabs = [];

    private ModelConfigResponse? _modelsData;
    private bool _modelsLoading;
    private bool _modelsSaving;
    private bool _saveSuccess;
    private string? _saveError;

    // Per-field binding
    private string _orchestratorModel = "";
    private string _composerModel = "";
    private string _compactionModel = "";
    private string _coderModel = "";
    private string _testerModel = "";
    private string _reviewerModel = "";
    private string _docwriterModel = "";
    private string _improverModel = "";

    protected override async Task OnInitializedAsync()
    {
        PageHeader.SetTitle("⚙️ Configuration");
        try
        {
            await LoadFilesAsync();
            await LoadModelsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadFilesAsync()
    {
        var basePath = ConfigRepo.LocalPath;

        // Load hive-config.yaml
        var configPath = Path.Combine(basePath, "hive-config.yaml");
        if (File.Exists(configPath))
            _files["hive-config.yaml"] = await File.ReadAllTextAsync(configPath);

        // Load agents/*.agents.md
        var agentsDir = Path.Combine(basePath, "agents");
        if (Directory.Exists(agentsDir))
        {
            foreach (var file in Directory.GetFiles(agentsDir, "*.agents.md").OrderBy(f => f))
            {
                var name = Path.GetFileName(file);
                _files[name] = await File.ReadAllTextAsync(file);
            }
        }

        _tabs = [.. _files.Keys];
        _tabs.Insert(0, ModelsTabName);
    }

    private async Task LoadModelsAsync()
    {
        _modelsLoading = true;
        try
        {
            _modelsData = await HttpClient.GetFromJsonAsync<ModelConfigResponse>("/api/config/models");
            if (_modelsData is not null)
            {
                _orchestratorModel = _modelsData.Orchestrator ?? "";
                _composerModel     = _modelsData.Composer ?? _modelsData.Orchestrator ?? "";
                _compactionModel   = _modelsData.Compaction ?? "";
                _coderModel        = _modelsData.Workers?.GetValueOrDefault("coder")?.Model
                                     ?? _modelsData.Orchestrator ?? "";
                _testerModel       = _modelsData.Workers?.GetValueOrDefault("tester")?.Model
                                     ?? _modelsData.Orchestrator ?? "";
                _reviewerModel     = _modelsData.Workers?.GetValueOrDefault("reviewer")?.Model
                                     ?? _modelsData.Orchestrator ?? "";
                _docwriterModel    = _modelsData.Workers?.GetValueOrDefault("docwriter")?.Model
                                     ?? _modelsData.Orchestrator ?? "";
                _improverModel     = _modelsData.Workers?.GetValueOrDefault("improver")?.Model
                                     ?? _modelsData.Orchestrator ?? "";
            }
        }
        catch (Exception ex)
        {
            _saveError = $"Failed to load model config: {ex.Message}";
        }
        finally
        {
            _modelsLoading = false;
        }
    }

    private async Task SaveModelsAsync()
    {
        _modelsSaving = true;
        _saveSuccess  = false;
        _saveError    = null;
        try
        {
            var body = new StringContent(
                System.Text.Json.JsonSerializer.Serialize(new
                {
                    orchestratorModel = _orchestratorModel,
                    composerModel      = _composerModel,
                    workerModels       = new Dictionary<string, string>
                    {
                        ["coder"]      = _coderModel,
                        ["tester"]     = _testerModel,
                        ["reviewer"]   = _reviewerModel,
                        ["docwriter"]  = _docwriterModel,
                        ["improver"]   = _improverModel,
                    },
                    compactionModel = _compactionModel,
                }),
                System.Text.Encoding.UTF8,
                "application/json");

            var response = await HttpClient.PatchAsync("/api/config/models", body);
            if (response.IsSuccessStatusCode)
            {
                await LoadModelsAsync();
                _saveSuccess = true;
                await Task.Delay(3000);
                _saveSuccess = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _saveError = $"Save failed ({(int)response.StatusCode}): {error}";
            }
        }
        catch (Exception ex)
        {
            _saveError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _modelsSaving = false;
            StateHasChanged();
        }
    }

    private string GetActiveContent() =>
        _files.TryGetValue(_activeTab, out var content) ? content : "(empty)";

    private string? ActiveTab => _activeTab;

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static string RenderMarkdown(string content) =>
        Markdown.ToHtml(content, MarkdownPipeline);

    private static string HighlightYaml(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        // Escape HTML first
        content = System.Net.WebUtility.HtmlEncode(content);
        // Comments (# ...) - muted color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"(#.*)$", "<span class=\"yaml-comment\">$1</span>",
            System.Text.RegularExpressions.RegexOptions.Multiline);
        // Booleans (true/false, case-insensitive) - distinct color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"\b(true|false)\b", "<span class=\"yaml-bool\">$1</span>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        // Numbers - distinct color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"\b(\d+\.?\d*)\b", "<span class=\"yaml-number\">$1</span>");
        // Keys (before colon, not indented with -) - accent color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"^(\s*)([a-zA-Z_][a-zA-Z0-9_-]*)\s*:",
            "$1<span class=\"yaml-key\">$2</span>:",
            System.Text.RegularExpressions.RegexOptions.Multiline);
        return content;
    }

    public void Dispose() { }
}
