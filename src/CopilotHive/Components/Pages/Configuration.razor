    private async Task AddRepositoryAsync()
    {
        _repoSaving = true;
        _repoError = null;
        _repoSuccess = null;
        if (string.IsNullOrWhiteSpace(_newRepoName) || string.IsNullOrWhiteSpace(_newRepoUrl))
        {
            _repoError = "Name and URL are required.";
            _repoSaving = false;
            return;
        }
        try
        {
            var branch = string.IsNullOrWhiteSpace(_newRepoDefaultBranch) ? "main" : _newRepoDefaultBranch;
            object? release = null;
            if (!string.IsNullOrWhiteSpace(_newRepoMergeTo) || !string.IsNullOrWhiteSpace(_newRepoTagBranch))
            {
                release = new { mergeTo = string.IsNullOrWhiteSpace(_newRepoMergeTo) ? null : _newRepoMergeTo, tagBranch = string.IsNullOrWhiteSpace(_newRepoTagBranch) ? null : _newRepoTagBranch };
            }
            var body = new StringContent(
                System.Text.Json.JsonSerializer.Serialize(new { name = _newRepoName, url = _newRepoUrl, defaultBranch = branch, release }),
                System.Text.Encoding.UTF8, "application/json");
            var response = await HttpClient.PostAsync("/api/config/repositories", body);
            if (response.IsSuccessStatusCode)
            {
                _newRepoName = ""; _newRepoUrl = ""; _newRepoDefaultBranch = "main"; _newRepoMergeTo = ""; _newRepoTagBranch = "";
                _showAddRepoForm = false;
                await LoadRepositoriesAsync();
                _repoSuccess = "✅ Repository added and cloned";
                await Task.Delay(3000);
                _repoSuccess = null;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _repoError = $"Add failed ({(int)response.StatusCode}): {error}";
            }
        }
        catch (Exception ex)
        {
            _repoError = $"Add failed: {ex.Message}";
        }
        finally { _repoSaving = false; StateHasChanged(); }
    }

    private async Task StartEditRepo(RepositoryDto repo)
    {
        _editingRepoName = repo.Name;
        _editRepoUrl = repo.Url;
        _editRepoDefaultBranch = repo.DefaultBranch;
        _editRepoMergeTo = repo.Release?.MergeTo ?? "";
        _editRepoTagBranch = repo.Release?.TagBranch ?? "";
        _repoError = null; _repoSuccess = null;

        _repoBranches = null;
        _loadingBranches = true;
        _branchLoadError = false;
        _branchFetchCts?.Cancel();
        _branchFetchCts?.Dispose();
        _branchFetchCts = new CancellationTokenSource();
        var token = _branchFetchCts.Token;
        var generation = ++_branchFetchGeneration;
        try
        {
            var branches = await HttpClient.GetFromJsonAsync<List<string>>(
                $"/api/config/repositories/{Uri.EscapeDataString(repo.Name)}/branches", token);
            if (generation == _branchFetchGeneration)
            {
                _repoBranches = branches;
            }
        }
        catch (OperationCanceledException) { /* stale request */ }
        catch
        {
            if (generation == _branchFetchGeneration)
                _branchLoadError = true;
        }
        finally
        {
            if (generation == _branchFetchGeneration)
                _loadingBranches = false;
        }
    }

    private void CancelEditRepo()
    {
        _branchFetchCts?.Cancel();
        _branchFetchCts?.Dispose();
        _branchFetchCts = null;
        _editingRepoName = null;
    }

    private async Task SaveEditRepoAsync()
    {
        if (_editingRepoName is null) return;
        _repoSaving = true;
        _repoError = null;
        _repoSuccess = null;
        try
        {
            var branch = string.IsNullOrWhiteSpace(_editRepoDefaultBranch) ? "main" : _editRepoDefaultBranch;
            // Always send a non-null release object on the edit (PUT) path so clearing both
            // fields replaces (and removes) any existing release config. UpdateRepositoryAsync
            // normalizes an empty object to null, effectively disabling release automation.
            object release = new
            {
                mergeTo = string.IsNullOrWhiteSpace(_editRepoMergeTo) ? null : _editRepoMergeTo,
                tagBranch = string.IsNullOrWhiteSpace(_editRepoTagBranch) ? null : _editRepoTagBranch
            };
            var body = new StringContent(
                System.Text.Json.JsonSerializer.Serialize(new { name = _editingRepoName, url = _editRepoUrl, defaultBranch = branch, release }),
                System.Text.Encoding.UTF8, "application/json");
            var response = await HttpClient.PutAsync($"/api/config/repositories/{Uri.EscapeDataString(_editingRepoName)}", body);
            if (response.IsSuccessStatusCode)
            {
                _editingRepoName = null;
                await LoadRepositoriesAsync();
                _repoSuccess = "✅ Repository updated";
                await Task.Delay(3000);
                _repoSuccess = null;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _repoError = $"Update failed ({(int)response.StatusCode}): {error}";
            }
        }
        catch (Exception ex)
        {
            _repoError = $"Update failed: {ex.Message}";
        }
        finally { _repoSaving = false; StateHasChanged(); }
    }

