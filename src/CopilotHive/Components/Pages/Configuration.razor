@page "/configuration"
@using CopilotHive.Configuration
@using CopilotHive.Dashboard
@using Markdig
@implements IDisposable
@inject ConfigRepoManager ConfigRepo

<h1>⚙️ Configuration</h1>
<p style="color:var(--text-muted);margin-bottom:1.5rem">
    Config repo: <code style="font-size:0.85rem">@ConfigRepo.LocalPath</code>
</p>

@if (_loading)
{
    <p style="color:var(--text-muted)">Loading configuration files…</p>
}
else if (_error is not null)
{
    <p style="color:var(--red)">Error loading configuration: @_error</p>
}
else
{
    <div class="config-tabs">
        @foreach (var tab in _tabs)
        {
            <button class="config-tab @(tab == _activeTab ? "active" : "")"
                    @onclick="() => _activeTab = tab">@tab</button>
        }
    </div>

    <div class="config-content">
        @if (ActiveTab?.EndsWith(".md") == true)
        {
            <div class="config-markdown">
                @((MarkupString)RenderMarkdown(GetActiveContent() ?? ""))
            </div>
        }
        else if (ActiveTab?.Contains("hive-config.yaml") == true)
        {
            <pre class="yaml-highlighted"><code>@((MarkupString)HighlightYaml(GetActiveContent() ?? ""))</code></pre>
        }
        else
        {
            <pre><code>@GetActiveContent()</code></pre>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string _activeTab = "hive-config.yaml";
    private readonly Dictionary<string, string> _files = [];
    private List<string> _tabs = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadFilesAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadFilesAsync()
    {
        var basePath = ConfigRepo.LocalPath;

        // Load hive-config.yaml
        var configPath = Path.Combine(basePath, "hive-config.yaml");
        if (File.Exists(configPath))
            _files["hive-config.yaml"] = await File.ReadAllTextAsync(configPath);

        // Load agents/*.agents.md
        var agentsDir = Path.Combine(basePath, "agents");
        if (Directory.Exists(agentsDir))
        {
            foreach (var file in Directory.GetFiles(agentsDir, "*.agents.md").OrderBy(f => f))
            {
                var name = Path.GetFileName(file);
                _files[name] = await File.ReadAllTextAsync(file);
            }
        }

        _tabs = [.. _files.Keys];
        if (_tabs.Count > 0 && !_tabs.Contains(_activeTab))
            _activeTab = _tabs[0];
    }

    private string GetActiveContent() =>
        _files.TryGetValue(_activeTab, out var content) ? content : "(empty)";

    private string? ActiveTab => _activeTab;

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static string RenderMarkdown(string content) =>
        Markdown.ToHtml(content, MarkdownPipeline);

    private static string HighlightYaml(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        // Escape HTML first
        content = System.Net.WebUtility.HtmlEncode(content);
        // Comments (# ...) - muted color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"(#.*)$", "<span class=\"yaml-comment\">$1</span>",
            System.Text.RegularExpressions.RegexOptions.Multiline);
        // Booleans (true/false, case-insensitive) - distinct color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"\b(true|false)\b", "<span class=\"yaml-bool\">$1</span>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        // Numbers - distinct color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"\b(\d+\.?\d*)\b", "<span class=\"yaml-number\">$1</span>");
        // Keys (before colon, not indented with -) - accent color
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"^(\s*)([a-zA-Z_][a-zA-Z0-9_-]*)\s*:",
            "$1<span class=\"yaml-key\">$2</span>:",
            System.Text.RegularExpressions.RegexOptions.Multiline);
        return content;
    }

    public void Dispose() { }
}
