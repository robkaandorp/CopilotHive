    private async Task LoadFilesAsync()
    {
        var basePath = ConfigRepo.LocalPath;

        // Load hive-config.yaml
        var configPath = Path.Combine(basePath, "hive-config.yaml");
        if (File.Exists(configPath))
            _files["hive-config.yaml"] = await File.ReadAllTextAsync(configPath);

        // Load agents/*.agents.md
        var agentsDir = Path.Combine(basePath, "agents");
        if (Directory.Exists(agentsDir))
        {
            foreach (var file in Directory.GetFiles(agentsDir, "*.agents.md").OrderBy(f => f))
            {
                var name = Path.GetFileName(file);
                _files[name] = await File.ReadAllTextAsync(file);
            }
        }

        _tabs = [.. _files.Keys];
        _tabs.Insert(0, ModelsTabName);
        _tabs.Insert(1, AvailableModelsTabName);
        _tabs.Insert(2, BackupTabName);
        _tabs.Insert(3, RepositoriesTabName);
        _tabs.Insert(4, OrchestratorTabName);
        _tabs.Insert(5, WorkersTabName);
        _tabs.Insert(6, ComposerTabName);
    }

