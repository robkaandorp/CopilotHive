@page "/configuration"
@using CopilotHive.Configuration
@using CopilotHive.Dashboard
@using Markdig
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject ConfigRepoManager ConfigRepo
@inject PageHeaderState PageHeader
@inject HttpClient HttpClient
@inject IJSRuntime JS

<p style="color:var(--text-muted);margin-bottom:1.5rem">
    Config repo: <code style="font-size:0.85rem">@ConfigRepo.LocalPath</code>
</p>

@if (_loading)
{
    <p style="color:var(--text-muted)">Loading configuration files…</p>
}
else if (_error is not null)
{
    <p style="color:var(--red)">Error loading configuration: @_error</p>
}
else
{
    <div class="config-tabs">
        @foreach (var tab in _tabs)
        {
            <button class="config-tab @(tab == _activeTab ? "active" : "")"
                    @onclick="() => _activeTab = tab">@tab</button>
        }
    </div>

    <div class="config-content">
        @if (_activeTab == ModelsTabName)
        {
            @if (_modelsLoading)
            {
                <p style="color:var(--text-muted)">Loading model configuration…</p>
            }
            else if (_modelsData?.AvailableModels is null || _modelsData.AvailableModels.Count == 0)
            {
                <p style="color:var(--text-muted);font-style:italic">
                    Configure <code>models.available_models</code> in <code>hive-config.yaml</code> to enable model selection.
                </p>
            }
            else
            {
                var models = _modelsData.AvailableModels;

                <div style="display:grid;grid-template-columns:14rem 1fr;gap:0.75rem 1rem;align-items:center;max-width:600px">

                    <label style="color:var(--text-muted);font-size:0.9rem">Orchestrator / Brain</label>
                    <select @bind="_orchestratorModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Composer</label>
                    <select @bind="_composerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Coder</label>
                    <select @bind="_coderModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Premium Coder</label>
                    <select @bind="_coderPremiumModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(none)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Tester</label>
                    <select @bind="_testerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Premium Tester</label>
                    <select @bind="_testerPremiumModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(none)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Reviewer</label>
                    <select @bind="_reviewerModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Premium Reviewer</label>
                    <select @bind="_reviewerPremiumModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(none)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Doc Writer</label>
                    <select @bind="_docwriterModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Premium Doc Writer</label>
                    <select @bind="_docwriterPremiumModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(none)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Improver</label>
                    <select @bind="_improverModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Premium Improver</label>
                    <select @bind="_improverPremiumModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(none)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                    <label style="color:var(--text-muted);font-size:0.9rem">Compaction model</label>
                    <select @bind="_compactionModel" style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                        <option value="">(use main model)</option>
                        @foreach (var m in models)
                        {
                            var displayText = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name} ({m.ReasoningEffort})";
                            var optionValue = string.IsNullOrEmpty(m.ReasoningEffort)
                                ? m.Name
                                : $"{m.Name}:{m.ReasoningEffort}";
                            <option value="@optionValue">@displayText</option>
                        }
                    </select>

                </div>

                <div style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem">
                    <button class="approve-btn" disabled="@_modelsSaving" @onclick="SaveModelsAsync">
                        @(_modelsSaving ? "Saving…" : "💾 Save")
                    </button>
                    @if (_saveSuccess)
                    {
                        <span style="color:var(--accent);font-size:0.9rem">✅ Saved successfully</span>
                    }
                    @if (_saveError is not null)
                    {
                        <span style="color:var(--red);font-size:0.9rem">@_saveError</span>
                    }
                </div>
            }
        }
        else if (_activeTab == AvailableModelsTabName)
        {
            <div style="margin-top:1rem">
                <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem">
                    <button class="approve-btn" disabled="@_discoveringModels" @onclick="BrowseProviderModelsAsync">
                        @(_discoveringModels ? "Discovering…" : "🔍 Browse Provider Models")
                    </button>
                    <button class="approve-btn" @onclick="() => { _showAddModelForm = !_showAddModelForm; _availableModelsError = null; _availableModelsSuccess = null; }">
                        ➕ Add Model
                    </button>
                    @if (_availableModelsSuccess is not null)
                    {
                        <span style="color:var(--accent);font-size:0.9rem">@_availableModelsSuccess</span>
                    }
                    @if (_availableModelsError is not null)
                    {
                        <span style="color:var(--red);font-size:0.9rem">@_availableModelsError</span>
                    }
                </div>

                @if (_showAddModelForm)
                {
                    <div style="margin-bottom:1.5rem;padding:1rem 1.25rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;max-width:700px">
                        <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.75rem">Add Model</h3>
                        <div style="display:grid;grid-template-columns:10rem 1fr;gap:0.75rem 1rem;align-items:center">
                            <label style="color:var(--text-muted);font-size:0.9rem">Name</label>
                            <input @bind="_newModelName" placeholder="e.g. copilot/claude-sonnet-4.6"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">Context Window</label>
                            <input type="number" @bind="_newModelContextWindow" placeholder="optional"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">Reasoning Effort</label>
                            <select @bind="_newModelReasoningEffort"
                                    style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;cursor:pointer;width:100%">
                                <option value="">none</option>
                                <option value="low">low</option>
                                <option value="medium">medium</option>
                                <option value="high">high</option>
                                <option value="extra_high">extra_high</option>
                            </select>
                        </div>
                        <div style="margin-top:1rem;display:flex;gap:0.75rem">
                            <button class="approve-btn" @onclick="AddModelAsync">💾 Save</button>
                            <button class="approve-btn" @onclick="() => _showAddModelForm = false">Cancel</button>
                        </div>
                    </div>
                }

                @{
                    var availableModels = _modelsData?.AvailableModels;
                }
                @if (availableModels is null || availableModels.Count == 0)
                {
                    <p style="color:var(--text-muted);font-style:italic">
                        No available models configured yet. Use "Browse Provider Models" or "Add Model" to add some.
                    </p>
                }
                else
                {
                    <table style="border-collapse:collapse;width:100%;max-width:800px">
                        <thead>
                            <tr style="border-bottom:1px solid var(--border)">
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Name</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Context Window</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Reasoning Effort</th>
                                <th style="text-align:right;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var model in availableModels)
                            {
                                <tr style="border-bottom:1px solid var(--border)">
                                    @if (_editingModelName == model.Name)
                                    {
                                        <td style="padding:0.5rem;font-size:0.9rem">@model.Name</td>
                                        <td style="padding:0.5rem">
                                            <input type="number" @bind="_editModelContextWindow" placeholder="optional"
                                                   style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;width:8rem" />
                                        </td>
                                        <td style="padding:0.5rem">
                                            <select @bind="_editModelReasoningEffort"
                                                    style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;cursor:pointer">
                                                <option value="">none</option>
                                                <option value="low">low</option>
                                                <option value="medium">medium</option>
                                                <option value="high">high</option>
                                                <option value="extra_high">extra_high</option>
                                            </select>
                                        </td>
                                        <td style="padding:0.5rem;text-align:right">
                                            <button class="approve-btn" @onclick="SaveEditModelAsync">💾 Save</button>
                                            <button class="approve-btn" @onclick="CancelEditModel">Cancel</button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="padding:0.5rem;font-size:0.9rem">@model.Name</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@(model.ContextWindow?.ToString() ?? "—")</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@(string.IsNullOrEmpty(model.ReasoningEffort) ? "—" : model.ReasoningEffort)</td>
                                        <td style="padding:0.5rem;text-align:right">
                                            <button class="approve-btn" @onclick="() => StartEditModel(model)">✏️ Edit</button>
                                            <button class="approve-btn" style="color:var(--red)" @onclick="() => RemoveModelAsync(model.Name)">🗑️ Remove</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (_showDiscoveryModal)
                {
                    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:1000"
                         @onclick="() => _showDiscoveryModal = false">
                        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:1.5rem;max-width:700px;width:90%;max-height:80vh;display:flex;flex-direction:column"
                             @onclick:stopPropagation="true">
                            <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:1rem">Discovered Provider Models</h3>
                            <div style="flex:1;overflow-y:auto;max-height:60vh">
                                @if (_discoveredModels.Count == 0)
                                {
                                    <p style="color:var(--text-muted);font-style:italic">No models discovered. Check provider credentials (GH_TOKEN, OLLAMA_API_KEY/OLLAMA_URL).</p>
                                }
                                else
                                {
                                    <div style="display:flex;flex-direction:column;gap:0.4rem;margin-bottom:1rem">
                                        @foreach (var dm in _discoveredModels)
                                        {
                                            <label style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.5rem;border:1px solid var(--border);border-radius:6px;cursor:pointer">
                                                <input type="checkbox"
                                                       checked="@_selectedDiscoveredIds.Contains(dm.Id)"
                                                       @onchange="(e) => ToggleDiscoveredSelection(dm.Id, (bool)(e.Value ?? false))" />
                                                <span style="font-size:0.9rem;flex:1">@dm.Name</span>
                                                <span style="font-size:0.8rem;color:var(--text-muted)">@dm.Id</span>
                                                @if (dm.Vendor is not null)
                                                {
                                                    <span style="font-size:0.75rem;color:var(--text-muted)">@dm.Vendor</span>
                                                }
                                                @if (dm.ContextWindow is not null)
                                                {
                                                    <span style="font-size:0.75rem;color:var(--text-muted)">@dm.ContextWindow.Value.ToString("N0") tok</span>
                                                }
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                            <div style="display:flex;gap:0.75rem;justify-content:flex-end">
                                <button class="approve-btn" disabled="@(_selectedDiscoveredIds.Count == 0)" @onclick="AddSelectedDiscoveredAsync">➕ Add Selected</button>
                                <button class="approve-btn" @onclick="() => _showDiscoveryModal = false">Close</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_activeTab == BackupTabName)
        {
            <div style="margin-top:1rem">
                <div style="margin-bottom:1.5rem">
                    <button class="approve-btn" disabled="@_backupCreating" @onclick="CreateBackupAsync">
                        @if (_backupCreating)
                        {
                            <span>Creating backup…</span>
                        }
                        else
                        {
                            <span>📦 Create Backup</span>
                        }
                    </button>
                    @if (_backupSuccess)
                    {
                        <span style="color:var(--accent);font-size:0.9rem;margin-left:1rem">✅ Backup created</span>
                    }
                    @if (_backupError is not null)
                    {
                        <span style="color:var(--red);font-size:0.9rem;margin-left:1rem">@_backupError</span>
                    }
                </div>

                @if (_backupsLoading)
                {
                    <p style="color:var(--text-muted)">Loading backups…</p>
                }
                else if (_backupError is null && _backups.Count == 0)
                {
                    <p style="color:var(--text-muted);font-style:italic">No backups yet. Click "Create Backup" to create one.</p>
                }
                else if (_backupError is null)
                {
                    <div style="display:flex;flex-direction:column;gap:0.75rem;max-width:700px">
                        @foreach (var backup in _backups)
                        {
                            <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px">
                                <div>
                                    <div style="font-size:0.9rem;font-weight:500">@backup.FileName</div>
                                    <div style="color:var(--text-muted);font-size:0.8rem">
                                        @FormatFileSize(backup.SizeBytes) · @backup.CreatedAt.ToString("yyyy-MM-dd HH:mm UTC")
                                    </div>
                                </div>
                                <a href="@($"/api/backup/{backup.FileName}")" style="color:var(--accent);font-size:0.85rem;text-decoration:none">Download</a>
                            </div>
                        }
                    </div>
                }

                <div style="margin-top:2rem;padding:1rem 1.25rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;max-width:700px">
                    <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.75rem">What's included</h3>
                    <ul style="color:var(--text-muted);font-size:0.85rem;list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem">
                        <li>✓ Database (copilothive.db)</li>
                        <li>✓ Brain master session (brain-master.json)</li>
                        <li>✓ Brain goal sessions (brain-goal-*.json)</li>
                        <li>✓ Composer session (composer-session.json)</li>
                        <li>✓ Metrics (metrics/)</li>
                        <li>✓ Data protection keys (keys/)</li>
                    </ul>
                </div>
            </div>
        }
        else if (_activeTab == RepositoriesTabName)
        {
            <div style="margin-top:1rem">
                <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem">
                    <button class="approve-btn" @onclick="() => { _showAddRepoForm = !_showAddRepoForm; _repoError = null; _repoSuccess = null; }">
                        ➕ Add Repository
                    </button>
                    @if (_repoSuccess is not null)
                    {
                        <span style="color:var(--accent);font-size:0.9rem">@_repoSuccess</span>
                    }
                    @if (_repoError is not null)
                    {
                        <span style="color:var(--red);font-size:0.9rem">@_repoError</span>
                    }
                </div>

                @if (_showAddRepoForm)
                {
                    <div style="margin-bottom:1.5rem;padding:1rem 1.25rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;max-width:700px">
                        <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.75rem">Add Repository</h3>
                        <div style="display:grid;grid-template-columns:10rem 1fr;gap:0.75rem 1rem;align-items:center">
                            <label style="color:var(--text-muted);font-size:0.9rem">Name</label>
                            <input @bind="_newRepoName" placeholder="e.g. my-app"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">URL</label>
                            <input @bind="_newRepoUrl" placeholder="https://github.com/org/repo.git"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">Default Branch</label>
                            <input @bind="_newRepoDefaultBranch" placeholder="main"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">Merge to branch on release (e.g. main)</label>
                            <input @bind="_newRepoMergeTo" placeholder="main (optional)"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                            <label style="color:var(--text-muted);font-size:0.9rem">Tag branch on release (e.g. main)</label>
                            <input @bind="_newRepoTagBranch" placeholder="main (optional)"
                                   style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />
                            <div style="grid-column:2;color:var(--text-muted);font-size:0.8rem">Branch dropdowns are available when editing an existing repository.</div>
                        </div>
                        <div style="margin-top:1rem;display:flex;gap:0.75rem">
                            <button class="approve-btn" disabled="@_repoSaving" @onclick="AddRepositoryAsync">@(_repoSaving ? "Saving…" : "💾 Save")</button>
                            <button class="approve-btn" @onclick="() => _showAddRepoForm = false">Cancel</button>
                        </div>
                    </div>
                }

                @if (_reposLoading)
                {
                    <p style="color:var(--text-muted)">Loading repositories…</p>
                }
                else if (_repositories.Count == 0)
                {
                    <p style="color:var(--text-muted);font-style:italic">No repositories configured yet. Click "Add Repository" to add one.</p>
                }
                else
                {
                    <table style="border-collapse:collapse;width:100%;max-width:900px">
                        <thead>
                            <tr style="border-bottom:1px solid var(--border)">
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Name</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">URL</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Default Branch</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Merge To</th>
                                <th style="text-align:left;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Tag Branch</th>
                                <th style="text-align:right;padding:0.5rem;color:var(--text-muted);font-size:0.85rem;font-weight:600">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _repositories)
                            {
                                <tr style="border-bottom:1px solid var(--border)">
                                    @if (_editingRepoName == r.Name)
                                    {
                                        <td style="padding:0.5rem;font-size:0.9rem">@r.Name</td>
                                        <td style="padding:0.5rem">
                                            <input @bind="_editRepoUrl"
                                                   style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;width:100%" />
                                        </td>
                                        <td style="padding:0.5rem">
                                            <select @bind="_editRepoDefaultBranch" title="Default working branch for this repository"
                                                    disabled="@(_loadingBranches || _branchLoadError)"
                                                    style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;width:8rem">
                                                @if (_loadingBranches)
                                                {
                                                    <option value="">Loading…</option>
                                                }
                                                else if (_branchLoadError)
                                                {
                                                    <option value="">⚠️ Failed to load</option>
                                                }
                                                else
                                                {
                                                    @if (_repoBranches is not null)
                                                    {
                                                        @foreach (var branch in _repoBranches)
                                                        {
                                                            <option value="@branch">@branch</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td style="padding:0.5rem">
                                            <select @bind="_editRepoMergeTo" title="Branch to merge the default branch into on release"
                                                    disabled="@(_loadingBranches || _branchLoadError)"
                                                    style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;width:8rem">
                                                @if (_loadingBranches)
                                                {
                                                    <option value="">Loading…</option>
                                                }
                                                else if (_branchLoadError)
                                                {
                                                    <option value="">⚠️ Failed to load</option>
                                                }
                                                else
                                                {
                                                    <option value="">— none —</option>
                                                    @if (_repoBranches is not null)
                                                    {
                                                        @foreach (var branch in _repoBranches)
                                                        {
                                                            <option value="@branch">@branch</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td style="padding:0.5rem">
                                            <select @bind="_editRepoTagBranch" title="Branch to tag on release"
                                                    disabled="@(_loadingBranches || _branchLoadError)"
                                                    style="padding:0.35rem 0.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;width:8rem">
                                                @if (_loadingBranches)
                                                {
                                                    <option value="">Loading…</option>
                                                }
                                                else if (_branchLoadError)
                                                {
                                                    <option value="">⚠️ Failed to load</option>
                                                }
                                                else
                                                {
                                                    <option value="">— none —</option>
                                                    @if (_repoBranches is not null)
                                                    {
                                                        @foreach (var branch in _repoBranches)
                                                        {
                                                            <option value="@branch">@branch</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td style="padding:0.5rem;text-align:right">
                                            <button class="approve-btn" disabled="@_repoSaving" @onclick="SaveEditRepoAsync">💾 Save</button>
                                            <button class="approve-btn" @onclick="CancelEditRepo">Cancel</button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="padding:0.5rem;font-size:0.9rem">@r.Name</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@r.Url</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@r.DefaultBranch</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@(r.Release?.MergeTo ?? "—")</td>
                                        <td style="padding:0.5rem;font-size:0.9rem">@(r.Release?.TagBranch ?? "—")</td>
                                        <td style="padding:0.5rem">
                                            <div style="display:flex;gap:0.5rem;justify-content:flex-end">
                                                <button class="approve-btn" @onclick="() => StartEditRepo(r)">✏️ Edit</button>
                                                <button class="approve-btn" style="color:var(--red)" @onclick="() => RemoveRepositoryAsync(r.Name)">🗑️ Remove</button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else if (_activeTab == OrchestratorTabName)
        {
            <div style="margin-top:1rem">
                @if (_orchestratorLoading)
                {
                    <p style="color:var(--text-muted)">Loading orchestrator settings…</p>
                }
                else
                {
                    <div style="display:grid;grid-template-columns:14rem 1fr;gap:0.75rem 1rem;align-items:center;max-width:600px">
                        <label style="color:var(--text-muted);font-size:0.9rem">Max Iterations</label>
                        <input type="number" min="1" @bind="_orchMaxIterations"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Max Retries Per Task</label>
                        <input type="number" min="0" @bind="_orchMaxRetriesPerTask"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Max Parallel Goals</label>
                        <input type="number" min="1" @bind="_orchMaxParallelGoals"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Always Improve</label>
                        <input type="checkbox" @bind="_orchAlwaysImprove" style="width:1.1rem;height:1.1rem;cursor:pointer" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Verbose Logging</label>
                        <input type="checkbox" @bind="_orchVerboseLogging" style="width:1.1rem;height:1.1rem;cursor:pointer" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Brain Max Steps</label>
                        <input type="number" @bind="_orchBrainMaxSteps"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Branch Cleanup Delay Hours</label>
                        <input type="number" min="0" @bind="_orchBranchCleanupDelayHours"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />
                    </div>

                    <div style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem">
                        <button class="approve-btn" disabled="@_orchestratorSaving" @onclick="SaveOrchestratorAsync">
                            @(_orchestratorSaving ? "Saving…" : "💾 Save")
                        </button>
                        @if (_orchestratorSaveSuccess is not null)
                        {
                            <span style="color:var(--accent);font-size:0.9rem">@_orchestratorSaveSuccess</span>
                        }
                        @if (_orchestratorSaveError is not null)
                        {
                            <span style="color:var(--red);font-size:0.9rem">@_orchestratorSaveError</span>
                        }
                    </div>
                }
            </div>
        }
        else if (_activeTab == WorkersTabName)
        {
            <div style="margin-top:1rem">
                @if (_workersLoading)
                {
                    <p style="color:var(--text-muted)">Loading worker settings…</p>
                }
                else
                {
                    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1rem">
                        Per-role context window overrides (in tokens). A value of <strong>0</strong> means "use orchestrator default".
                    </p>
                    <div style="display:grid;grid-template-columns:14rem 1fr;gap:0.75rem 1rem;align-items:center;max-width:600px">
                        <label style="color:var(--text-muted);font-size:0.9rem">Coder</label>
                        <input type="number" min="0" @bind="_coderContextWindow"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Tester</label>
                        <input type="number" min="0" @bind="_testerContextWindow"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Reviewer</label>
                        <input type="number" min="0" @bind="_reviewerContextWindow"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Doc Writer</label>
                        <input type="number" min="0" @bind="_docwriterContextWindow"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />

                        <label style="color:var(--text-muted);font-size:0.9rem">Improver</label>
                        <input type="number" min="0" @bind="_improverContextWindow"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />
                    </div>

                    <div style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem">
                        <button class="approve-btn" disabled="@_workersSaving" @onclick="SaveWorkerContextWindowsAsync">
                            @(_workersSaving ? "Saving…" : "💾 Save")
                        </button>
                        @if (_workersSaveSuccess is not null)
                        {
                            <span style="color:var(--accent);font-size:0.9rem">@_workersSaveSuccess</span>
                        }
                        @if (_workersSaveError is not null)
                        {
                            <span style="color:var(--red);font-size:0.9rem">@_workersSaveError</span>
                        }
                    </div>
                }
            </div>
        }
        else if (_activeTab == ComposerTabName)
        {
            <div style="margin-top:1rem">
                @if (_composerLoading)
                {
                    <p style="color:var(--text-muted)">Loading composer settings…</p>
                }
                else
                {
                    @if (_composerData is null)
                    {
                        <p style="color:var(--text-muted);font-style:italic;margin-bottom:1rem">Composer is not configured yet. Set values below and save to create it.</p>
                    }
                    <div style="display:grid;grid-template-columns:14rem 1fr;gap:0.75rem 1rem;align-items:center;max-width:600px">
                        <label style="color:var(--text-muted);font-size:0.9rem">Max Steps</label>
                        <input type="number" @bind="_composerMaxSteps"
                               style="padding:0.5rem 0.75rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.9rem;width:100%" />
                    </div>

                    <div style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem">
                        <button class="approve-btn" disabled="@_composerSaving" @onclick="SaveComposerAsync">
                            @(_composerSaving ? "Saving…" : "💾 Save")
                        </button>
                        @if (_composerSaveSuccess is not null)
                        {
                            <span style="color:var(--accent);font-size:0.9rem">@_composerSaveSuccess</span>
                        }
                        @if (_composerSaveError is not null)
                        {
                            <span style="color:var(--red);font-size:0.9rem">@_composerSaveError</span>
                        }
                    </div>
                }
            </div>
        }
        else if (ActiveTab?.EndsWith(".md") == true)
        {
            <div class="config-markdown">
                @((MarkupString)RenderMarkdown(GetActiveContent() ?? ""))
            </div>
        }
        else if (ActiveTab?.Contains("hive-config.yaml") == true)
        {
            <pre class="yaml-highlighted"><code>@((MarkupString)HighlightYaml(GetActiveContent() ?? ""))</code></pre>
        }
        else
        {
            <pre><code>@GetActiveContent()</code></pre>
        }
    </div>
}

@code {
    private const string ModelsTabName = "Models";
    private const string AvailableModelsTabName = "Available Models";
    private const string BackupTabName = "Backup";
    private const string RepositoriesTabName = "Repositories";
    private const string OrchestratorTabName = "Orchestrator";
    private const string WorkersTabName = "Workers";
    private const string ComposerTabName = "Composer";

    private sealed record ModelConfigResponse(
        [property: JsonPropertyName("orchestrator")]    string? Orchestrator,
        [property: JsonPropertyName("composer")]        string? Composer,
        [property: JsonPropertyName("compaction")]      string? Compaction,
        [property: JsonPropertyName("workers")]         Dictionary<string, WorkerConfigDto>? Workers,
        [property: JsonPropertyName("availableModels")] List<ModelEntryDto>? AvailableModels);

    private sealed record WorkerConfigDto(
        [property: JsonPropertyName("model")] string? Model,
        [property: JsonPropertyName("premiumModel")] string? PremiumModel);

    private sealed record ModelEntryDto(
        [property: JsonPropertyName("name")] string Name,
        [property: JsonPropertyName("contextWindow")] int? ContextWindow,
        [property: JsonPropertyName("reasoningEffort")] string? ReasoningEffort);

    private sealed record DiscoveredModelDto(
        [property: JsonPropertyName("id")] string Id,
        [property: JsonPropertyName("name")] string Name,
        [property: JsonPropertyName("vendor")] string? Vendor,
        [property: JsonPropertyName("contextWindow")] int? ContextWindow,
        [property: JsonPropertyName("enabled")] bool Enabled);

    private sealed record BackupInfoResponse(
        [property: JsonPropertyName("fileName")] string FileName,
        [property: JsonPropertyName("sizeBytes")] long SizeBytes,
        [property: JsonPropertyName("createdAt")] DateTime CreatedAt);

    private sealed record RepositoryDto(
        [property: JsonPropertyName("name")] string Name,
        [property: JsonPropertyName("url")] string Url,
        [property: JsonPropertyName("defaultBranch")] string DefaultBranch,
        [property: JsonPropertyName("release")] ReleaseDto? Release);

    private sealed record ReleaseDto(
        [property: JsonPropertyName("mergeTo")] string? MergeTo,
        [property: JsonPropertyName("tagBranch")] string? TagBranch);

    private sealed record OrchestratorConfigResponse(
        [property: JsonPropertyName("model")] string? Model,
        [property: JsonPropertyName("maxIterations")] int MaxIterations,
        [property: JsonPropertyName("maxRetriesPerTask")] int MaxRetriesPerTask,
        [property: JsonPropertyName("maxParallelGoals")] int MaxParallelGoals,
        [property: JsonPropertyName("alwaysImprove")] bool AlwaysImprove,
        [property: JsonPropertyName("verboseLogging")] bool VerboseLogging,
        [property: JsonPropertyName("brainMaxSteps")] int BrainMaxSteps,
        [property: JsonPropertyName("branchCleanupDelayHours")] int BranchCleanupDelayHours);

    private sealed record WorkerResponseDto(
        [property: JsonPropertyName("model")] string? Model,
        [property: JsonPropertyName("premiumModel")] string? PremiumModel,
        [property: JsonPropertyName("contextWindow")] int ContextWindow);

    private sealed record ComposerConfigResponse(
        [property: JsonPropertyName("model")] string? Model,
        [property: JsonPropertyName("maxSteps")] int MaxSteps);

    private bool _loading = true;
    private string? _error;
    private string _activeTab = ModelsTabName;
    private readonly Dictionary<string, string> _files = [];
    private List<string> _tabs = [];

    private ModelConfigResponse? _modelsData;
    private bool _modelsLoading;
    private bool _modelsSaving;
    private bool _saveSuccess;
    private string? _saveError;

    // Per-field binding
    private string _orchestratorModel = "";
    private string _composerModel = "";
    private string _compactionModel = "";
    private string _coderModel = "";
    private string _testerModel = "";
    private string _reviewerModel = "";
    private string _docwriterModel = "";
    private string _improverModel = "";
    private string _coderPremiumModel = "";
    private string _testerPremiumModel = "";
    private string _reviewerPremiumModel = "";
    private string _docwriterPremiumModel = "";
    private string _improverPremiumModel = "";

    private List<BackupInfoResponse> _backups = [];
    private bool _backupsLoading;
    private bool _backupCreating;
    private string? _backupError;
    private bool _backupSuccess;

    // Available Models tab state
    private List<DiscoveredModelDto> _discoveredModels = [];
    private bool _discoveringModels;
    private bool _showDiscoveryModal;
    private HashSet<string> _selectedDiscoveredIds = [];
    private bool _showAddModelForm;
    private string _newModelName = "";
    private int? _newModelContextWindow;
    private string _newModelReasoningEffort = "";
    private string? _editingModelName;
    private int? _editModelContextWindow;
    private string _editModelReasoningEffort = "";
    private string? _availableModelsError;
    private string? _availableModelsSuccess;

    // Repositories tab
    private List<RepositoryDto> _repositories = [];
    private bool _reposLoading;
    private bool _repoSaving;
    private string? _repoError;
    private string? _repoSuccess;
    private bool _showAddRepoForm;
    private string _newRepoName = "";
    private string _newRepoUrl = "";
    private string _newRepoDefaultBranch = "main";
    private string _newRepoMergeTo = "";
    private string _newRepoTagBranch = "";
    private string? _editingRepoName;
    private string _editRepoUrl = "";
    private string _editRepoDefaultBranch = "main";
    private string _editRepoMergeTo = "";
    private string _editRepoTagBranch = "";
    private List<string>? _repoBranches;
    private bool _loadingBranches;
    private bool _branchLoadError;
    private CancellationTokenSource? _branchFetchCts;
    private int _branchFetchGeneration;

    // Orchestrator tab
    private OrchestratorConfigResponse? _orchestratorData;
    private bool _orchestratorLoading;
    private bool _orchestratorSaving;
    private string? _orchestratorSaveError;
    private string? _orchestratorSaveSuccess;
    private int _orchMaxIterations;
    private int _orchMaxRetriesPerTask;
    private int _orchMaxParallelGoals;
    private bool _orchAlwaysImprove;
    private bool _orchVerboseLogging;
    private int _orchBrainMaxSteps;
    private int _orchBranchCleanupDelayHours;

    // Workers tab
    private Dictionary<string, WorkerResponseDto>? _workersData;
    private bool _workersLoading;
    private bool _workersSaving;
    private string? _workersSaveError;
    private string? _workersSaveSuccess;
    private int _coderContextWindow;
    private int _testerContextWindow;
    private int _reviewerContextWindow;
    private int _docwriterContextWindow;
    private int _improverContextWindow;

    // Composer tab
    private ComposerConfigResponse? _composerData;
    private bool _composerLoading;
    private bool _composerSaving;
    private string? _composerSaveError;
    private string? _composerSaveSuccess;
    private int _composerMaxSteps;

    protected override async Task OnInitializedAsync()
    {
        PageHeader.SetTitle("⚙️ Configuration");
        try
        {
            await LoadFilesAsync();
            await LoadModelsAsync();
            await LoadBackupsAsync();
            await LoadRepositoriesAsync();
            await LoadOrchestratorAsync();
