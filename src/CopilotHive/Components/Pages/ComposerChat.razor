@page "/composer"
@using CopilotHive.Dashboard
@using CopilotHive.Orchestration
@using Markdig
@implements IDisposable
@inject Composer Composer
@inject ClarificationQueueService ClarificationQueue
@inject IJSRuntime JS
@inject PageHeaderState PageHeader
@inject HttpClient HttpClient

@if (!Composer.IsConnected)
{
    <div class="chat-status chat-status-error">
        Composer is not connected. Check orchestrator logs.
    </div>
}
else
{
    <div class="composer-layout">
        <div class="chat-container">
            <div class="chat-messages" id="chat-messages">
                @if (_messages.Count == 0 && !Composer.IsStreaming)
                {
                    <div class="chat-empty">
                        <p><strong>Welcome to the Composer.</strong></p>
                        <p>Describe what you'd like to build or improve, and I'll help break it into goals.</p>
                        <p class="text-muted">Try: <em>"I want to add user authentication to the API"</em></p>
                    </div>
                }

                @foreach (var msg in _messages)
                {
                    <div class="chat-msg chat-msg-@msg.Role">
                        <div class="chat-msg-role">@(msg.Role == "user" ? "You" : "Composer")</div>
                        <div class="chat-msg-content">@((MarkupString)FormatContent(msg.Content))</div>
                    </div>
                }

                @if (Composer.IsStreaming)
                {
                    <div class="chat-msg chat-msg-assistant">
                        <div class="chat-msg-role">Composer</div>
                        <div class="chat-msg-content">
                            @((MarkupString)FormatStreamingContent(Composer.StreamingContent))
                            <span class="chat-cursor">▊</span>
                        </div>
                    </div>
                }

                @if (Composer.PendingQuestion is { } pq)
                {
                    <div class="chat-msg chat-msg-assistant chat-question-widget">
                        <div class="chat-msg-role">Composer — Question</div>
                        <div class="chat-msg-content">
                            <div class="chat-question-text">@((MarkupString)FormatContent(pq.Text))</div>

                            @if (pq.Type == QuestionType.YesNo)
                            {
                                <div class="chat-question-actions">
                                    <button class="chat-send chat-question-yes"
                                            @onclick="() => SubmitYesNo(true, pq)">Yes</button>
                                    <button class="chat-action-btn chat-question-no"
                                            @onclick="() => SubmitYesNo(false, pq)">No</button>
                                    <button class="chat-action-btn"
                                            @onclick="() => CancelQuestion(pq)">Cancel</button>
                                </div>
                                <textarea class="chat-input chat-question-feedback"
                                          @bind="_questionFeedback"
                                          placeholder="Optional additional feedback…"
                                          rows="2"></textarea>
                            }
                            else if (pq.Type == QuestionType.SingleChoice)
                            {
                                <div class="chat-question-options">
                                    @foreach (var opt in pq.Options)
                                    {
                                        <label class="chat-question-option">
                                            <input type="radio"
                                                   name="single-choice"
                                                   checked="@(_selectedOptions.Contains(opt))"
                                                   @onchange="() => SelectSingle(opt)" />
                                            @opt
                                        </label>
                                    }
                                </div>
                                <textarea class="chat-input chat-question-feedback"
                                          @bind="_questionFeedback"
                                          placeholder="Optional additional feedback…"
                                          rows="2"></textarea>
                                <div class="chat-question-actions">
                                    <button class="chat-send"
                                            disabled="@(_selectedOptions.Count == 0)"
                                            @onclick="() => SubmitChoice(pq)">Submit</button>
                                    <button class="chat-action-btn"
                                            @onclick="() => CancelQuestion(pq)">Cancel</button>
                                </div>
                            }
                            else if (pq.Type == QuestionType.MultiChoice)
                            {
                                <div class="chat-question-options">
                                    @foreach (var opt in pq.Options)
                                    {
                                        <label class="chat-question-option">
                                            <input type="checkbox"
                                                   checked="@(_selectedOptions.Contains(opt))"
                                                   @onchange="() => ToggleOption(opt)" />
                                            @opt
                                        </label>
                                    }
                                </div>
                                <textarea class="chat-input chat-question-feedback"
                                          @bind="_questionFeedback"
                                          placeholder="Optional additional feedback…"
                                          rows="2"></textarea>
                                <div class="chat-question-actions">
                                    <button class="chat-send"
                                            disabled="@(_selectedOptions.Count == 0)"
                                            @onclick="() => SubmitChoice(pq)">Submit</button>
                                    <button class="chat-action-btn"
                                            @onclick="() => CancelQuestion(pq)">Cancel</button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div id="chat-anchor"></div>
            </div>

            <div class="chat-input-area">
                <textarea @bind="_inputText" @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          placeholder="Describe what you want to build…"
                          disabled="@Composer.IsStreaming"
                          rows="2"
                          class="chat-input"></textarea>
                <button @onclick="SendMessage" disabled="@(Composer.IsStreaming || string.IsNullOrWhiteSpace(_inputText))"
                        class="chat-send">
                    @if (Composer.IsStreaming)
                    {
                        <span>Thinking…</span>
                    }
                    else
                    {
                        <span>Send</span>
                    }
                </button>
            </div>

            <div class="chat-actions">
                <select disabled="@Composer.IsStreaming" class="chat-model-select" @onchange="HandleModelChange">
                    @foreach (var model in _availableModels)
                    {
                        <option value="@model" selected="@(_selectedModel == model)">@model</option>
                    }
                </select>
                <button @onclick="ResetSession" disabled="@Composer.IsStreaming" class="chat-action-btn">
                    🔄 New Session
                </button>
                <span class="text-muted chat-hint">
                    @(_messages.Count) messages
                    @if (Composer.LastToolCalls > 0)
                    {
                        <text> · @Composer.LastToolCalls tool calls</text>
                    }
                </span>
            </div>
        </div>

        @* ── Clarification sidebar panel ── *@
        @if (_pendingClarifications.Count > 0 || _showClarificationPanel)
        {
            <div class="clarification-panel">
                <div class="clarification-panel-header" @onclick="ToggleClarificationPanel">
                    <h3>🔔 Clarifications (@_pendingClarifications.Count)</h3>
                    <button class="chat-action-btn">@(_showClarificationPanel ? "▼" : "▶")</button>
                </div>

                @if (_showClarificationPanel)
                {
                    <div class="clarification-panel-body">
                        @foreach (var req in _pendingClarifications)
                        {
                            <div class="clarification-item">
                                <div class="clarification-meta">
                                    <span class="badge badge-muted">@req.GoalId</span>
                                    <span class="badge badge-yellow">@req.WorkerRole</span>
                                    <span class="text-muted">@req.RequestedAt.ToString("HH:mm:ss")</span>
                                </div>
                                <div class="clarification-question">@req.Question</div>
                                <div class="clarification-answer-area">
                                    <textarea class="chat-input clarification-answer-input"
                                              @bind="_clarificationAnswers[req.Id]"
                                              placeholder="Type your answer…"
                                              rows="2"></textarea>
                                    <button class="chat-send clarification-submit-btn"
                                            disabled="@(string.IsNullOrWhiteSpace(GetClarificationAnswer(req.Id)))"
                                            @onclick="() => SubmitClarificationAnswer(req.Id)">
                                        Submit
                                    </button>
                                </div>
                            </div>
                        }

                        @if (_pendingClarifications.Count == 0)
                        {
                            <div class="text-muted" style="padding: 1rem;">No pending clarifications.</div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private sealed class ChatMessage
    {
        public required string Role { get; init; }
        public string Content { get; set; } = "";
    }

    private readonly List<ChatMessage> _messages = [];
    private string _inputText = "";
    private HashSet<string> _selectedOptions = [];
    private string _questionFeedback = "";
    private List<string> _availableModels = [];
    private string _selectedModel = "";

    // Clarification panel state
    private List<ClarificationRequest> _pendingClarifications = [];
    private bool _showClarificationPanel = true;
    private readonly Dictionary<string, string> _clarificationAnswers = new();

    protected override async Task OnInitializedAsync()
    {
        PageHeader.SetTitle("💬 Composer");
        if (Composer.IsConnected)
        {
            LoadHistory();
            await LoadAvailableModelsAsync();
            await LoadCurrentModelAsync();
            StateHasChanged();
        }
        Composer.OnStreamingUpdate += HandleStreamingUpdate;
        Composer.OnQuestionAsked += HandleQuestionAsked;
        ClarificationQueue.OnChanged += HandleClarificationChanged;
        RefreshClarifications();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("eval",
            "document.getElementById('chat-anchor')?.scrollIntoView()");
    }

    private void LoadHistory()
    {
        _messages.Clear();
        foreach (var (role, content) in Composer.GetChatHistory())
        {
            _messages.Add(new ChatMessage { Role = role, Content = content });
        }
    }

    private void HandleStreamingUpdate()
    {
        InvokeAsync(() =>
        {
            // When streaming finishes, reload history to get the final message
            if (!Composer.IsStreaming)
            {
                LoadHistory();
            }
            StateHasChanged();
        });
    }

    private void SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrEmpty(text) || Composer.IsStreaming) return;

        _messages.Add(new ChatMessage { Role = "user", Content = text });
        _inputText = "";
        Composer.SendMessage(text);
        StateHasChanged();
    }

    private async Task ResetSession()
    {
        if (Composer.IsStreaming) return;
        await Composer.ResetSessionAsync();
        _messages.Clear();
        StateHasChanged();
    }

    private async Task LoadAvailableModelsAsync()
    {
        try
        {
            var response = await HttpClient.GetFromJsonAsync<ModelsResponse>("/api/composer/models");
            if (response?.Models is { Count: > 0 })
            {
                _availableModels = response.Models;
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ComposerChat] Failed to load available models: {ex.Message}");
        }
    }

    /// <summary>
    /// Fetches the Composer's actual current model and sets it as the initial
    /// dropdown selection, ensuring correctness after a runtime model switch.
    /// </summary>
    private async Task LoadCurrentModelAsync()
    {
        try
        {
            var response = await HttpClient.GetFromJsonAsync<CurrentModelResponse>("/api/composer/current-model");
            if (!string.IsNullOrWhiteSpace(response?.Model) && _availableModels.Contains(response.Model))
            {
                _selectedModel = response.Model;
            }
            else if (_availableModels.Count > 0)
            {
                // Fallback: Composer model not in list or API returned empty, use first available
                _selectedModel = _availableModels[0];
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ComposerChat] Failed to load current model: {ex.Message}");
            // Fallback to first available model on error
            if (_availableModels.Count > 0)
            {
                _selectedModel = _availableModels[0];
            }
        }
    }

    private async Task HandleModelChange(ChangeEventArgs e)
    {
        if (e.Value is not string model || string.IsNullOrWhiteSpace(model)) return;
        if (!_availableModels.Contains(model)) return;

        try
        {
            var response = await HttpClient.PostAsJsonAsync($"/api/composer/models/switch?model={Uri.EscapeDataString(model)}", (object?)null);
            if (response.IsSuccessStatusCode)
            {
                _selectedModel = model;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Console.Error.WriteLine($"[ComposerChat] Model switch failed: {error?.Error ?? response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ComposerChat] Model switch failed: {ex.Message}");
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            SendMessage();
        }
    }

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static string FormatContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return Markdown.ToHtml(content, MarkdownPipeline);
    }

    private static string FormatStreamingContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return Markdown.ToHtml(content, MarkdownPipeline);
    }

    public void Dispose()
    {
        Composer.OnStreamingUpdate -= HandleStreamingUpdate;
        Composer.OnQuestionAsked -= HandleQuestionAsked;
        ClarificationQueue.OnChanged -= HandleClarificationChanged;
    }

    private void HandleQuestionAsked()
    {
        InvokeAsync(StateHasChanged);
    }

    private void SelectSingle(string option)
    {
        _selectedOptions = [option];
    }

    private void ToggleOption(string option)
    {
        if (_selectedOptions.Contains(option))
            _selectedOptions.Remove(option);
        else
            _selectedOptions.Add(option);
    }

    private void SubmitYesNo(bool yes, ComposerQuestion question)
    {
        var answer = yes ? "Yes" : "No";
        if (!string.IsNullOrWhiteSpace(_questionFeedback))
            answer += $" — {_questionFeedback.Trim()}";

        _selectedOptions = [];
        _questionFeedback = "";
        Composer.SubmitAnswer(answer);
        StateHasChanged();
    }

    private void SubmitChoice(ComposerQuestion question)
    {
        var selected = string.Join(", ", _selectedOptions);
        var answer = string.IsNullOrWhiteSpace(_questionFeedback)
            ? selected
            : $"{selected} — {_questionFeedback.Trim()}";

        _selectedOptions = [];
        _questionFeedback = "";
        Composer.SubmitAnswer(answer);
        StateHasChanged();
    }

    private void CancelQuestion(ComposerQuestion question)
    {
        _selectedOptions = [];
        _questionFeedback = "";
        Composer.CancelQuestion();
        StateHasChanged();
    }

    // ── Clarification panel methods ──

    private void HandleClarificationChanged()
    {
        InvokeAsync(() =>
        {
            RefreshClarifications();
            StateHasChanged();
        });
    }

    private void RefreshClarifications()
    {
        _pendingClarifications = ClarificationQueue.GetPendingHumanRequests().ToList();
        // Ensure answer inputs exist for all pending requests
        foreach (var req in _pendingClarifications)
        {
            _clarificationAnswers.TryAdd(req.Id, "");
        }
    }

    private void ToggleClarificationPanel()
    {
        _showClarificationPanel = !_showClarificationPanel;
    }

    private string GetClarificationAnswer(string requestId)
    {
        _clarificationAnswers.TryGetValue(requestId, out var answer);
        return answer ?? "";
    }

    private void SubmitClarificationAnswer(string requestId)
    {
        if (!_clarificationAnswers.TryGetValue(requestId, out var answer) ||
            string.IsNullOrWhiteSpace(answer))
            return;

        ClarificationQueue.SubmitAnswer(requestId, answer.Trim(), "human");
        _clarificationAnswers.Remove(requestId);
        RefreshClarifications();
        StateHasChanged();
    }

    private sealed record ModelsResponse(List<string> Models);
    private sealed record CurrentModelResponse(string Model);
    private sealed record ErrorResponse(string Error);
}
