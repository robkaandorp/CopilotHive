@page "/workers"
@using CopilotHive.Dashboard
@implements IDisposable
@inject DashboardStateService State
@inject PageHeaderState PageHeader

<div class="cards">
    <div class="card">
        <div class="label">Total</div>
        <div class="value">@_snap.TotalWorkers</div>
    </div>
    <div class="card">
        <div class="label">Busy</div>
        <div class="value" style="color:var(--accent)">@_snap.BusyWorkers</div>
    </div>
    <div class="card">
        <div class="label">Idle</div>
        <div class="value" style="color:var(--green)">@_snap.IdleWorkers</div>
    </div>
</div>

@if (_snap.Workers.Count > 0)
{
    <table>
        <thead>
            <tr>
                <th>Worker ID</th>
                <th>Role</th>
                <th>Model</th>
                <th>Ctx</th>
                <th>Status</th>
                <th>Current Task</th>
                <th>Last Heartbeat</th>
                <th>Connected</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var w in _snap.Workers)
            {
                <tr>
                    <td style="font-family:monospace;font-size:0.85rem">
                        <a href="/workers/@w.Id" style="color:var(--accent);text-decoration:none">@w.Id[..Math.Min(12, w.Id.Length)]</a>
                    </td>
                    <td>
                        @if (w.Role != "Unspecified")
                        {
                            <span class="badge badge-blue">@w.Role</span>
                        }
                        else
                        {
                            <span style="color:var(--text-muted)">—</span>
                        }
                    </td>
                    <td style="font-family:monospace;font-size:0.85rem;color:var(--text-muted)">
                        @{ var modelStr = w.GetDisplayModel(_info.RoleModels); }
                        @if (modelStr is not null)
                        {
                            @StripReasoning(modelStr)
                            @ReasoningBadge(modelStr)
                        }
                        else
                        {
                            <text>—</text>
                        }
                    </td>
                    <td style="font-family:monospace;font-size:0.85rem">
                        @if (w.IsBusy && w.ContextUsagePercent > 0)
                        {
                            var color = w.ContextUsagePercent switch
                            {
                                < 50 => "var(--green)",
                                < 80 => "var(--amber)",
                                _ => "var(--red)"
                            };
                            <span style="color:@color">@w.ContextUsagePercent%</span>
                        }
                        else
                        {
                            <span style="color:var(--text-muted)">—</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(w.IsBusy ? "badge-yellow" : "badge-green")">
                            @(w.IsBusy ? "Busy" : "Idle")
                        </span>
                    </td>
                    <td style="font-size:0.85rem">@(w.CurrentTaskId ?? "—")</td>
                    <td style="color:var(--text-muted);font-size:0.85rem">@FormatAgo(w.LastHeartbeat)</td>
                    <td style="color:var(--text-muted);font-size:0.85rem">@FormatAgo(w.ConnectedAt)</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p style="color:var(--text-muted)">No workers connected.</p>
}

@code {
    private DashboardSnapshot _snap = new();
    private OrchestratorInfo _info = new();

    protected override void OnInitialized()
    {
        PageHeader.SetTitle("🐝 Workers");
        _snap = State.GetSnapshot();
        _info = State.GetOrchestratorInfo();
        State.OnStateChanged += RefreshState;
    }

    private void RefreshState() => InvokeAsync(() =>
    {
        _snap = State.GetSnapshot();
        _info = State.GetOrchestratorInfo();
        StateHasChanged();
    });

    private static string FormatAgo(DateTime utc)
    {
        var ago = DateTime.UtcNow - utc;
        if (ago.TotalSeconds < 60) return $"{(int)ago.TotalSeconds}s ago";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        return $"{(int)ago.TotalHours}h {ago.Minutes}m ago";
    }

    private static readonly HashSet<string> KnownReasoningLevels = new(StringComparer.OrdinalIgnoreCase)
        { "none", "low", "medium", "high", "extra_high" };

    private static string StripReasoning(string model)
    {
        var lastColon = model.LastIndexOf(':');
        if (lastColon <= 0 || lastColon == model.Length - 1) return model;
        var suffix = model[(lastColon + 1)..];
        return KnownReasoningLevels.Contains(suffix) ? model[..lastColon] : model;
    }

    private static RenderFragment ReasoningBadge(string model) => builder =>
    {
        var lastColon = model.LastIndexOf(':');
        if (lastColon <= 0 || lastColon == model.Length - 1) return;
        var suffix = model[(lastColon + 1)..];
        if (!KnownReasoningLevels.Contains(suffix)) return;

        var color = suffix.ToLowerInvariant() switch
        {
            "extra_high" => "var(--red)",
            "high" => "var(--accent)",
            "medium" => "var(--green)",
            "low" => "var(--text-muted)",
            _ => "var(--text-muted)",
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "badge");
        builder.AddAttribute(2, "style", $"background:{color};color:#fff;font-size:0.7rem;margin-left:0.5rem");
        builder.AddContent(3, suffix);
        builder.CloseElement();
    };

    public void Dispose() => State.OnStateChanged -= RefreshState;
}
