@page "/goals/{GoalId}"
@using CopilotHive.Dashboard
@using CopilotHive.Goals
@using CopilotHive.Orchestration
@using CopilotHive.Services
@using Markdig
@implements IDisposable
@inject DashboardStateService State
@inject IGoalStore GoalStore
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HttpClient HttpClient
@inject PageHeaderState PageHeader

@if (_detail is not null || _storedGoal is not null)
{
    <div class="goal-detail-page">
        @* ===== TOP STRIP — metadata ===== *@
        <div class="goal-detail-top">
            <div class="goal-detail-meta-row">
                @* Repo tags *@
                @{
                    var repoNames = _storedGoal?.RepositoryNames ?? _detail?.RepositoryNames ?? [];
                }
                @foreach (var repo in repoNames)
                {
                    <span class="repo-tag">@repo</span>
                }

                @* Status badge *@
                @if (_detail is not null)
                {
                    <span class="badge @StatusBadge(_detail.Status)">@_detail.Status</span>
                }
                else if (_storedGoal is not null)
                {
                    <span class="badge @StatusBadge(_storedGoal.Status)">@_storedGoal.Status</span>
                }

                @* Priority *@
                @if (_detail is not null)
                {
                    <span style="color:var(--text-muted)">Priority: @_detail.Priority</span>
                }
                else if (_storedGoal is not null)
                {
                    <span style="color:var(--text-muted)">Priority: @_storedGoal.Priority</span>
                }

                @* Scope *@
                @if (_detail is not null)
                {
                    <span style="color:var(--text-muted)" title="@_detail.Scope.ToDisplayName()">@ScopeEmoji(_detail.Scope) @_detail.Scope.ToDisplayName()</span>
                }
                else if (_storedGoal is not null)
                {
                    <span style="color:var(--text-muted)" title="@_storedGoal.Scope.ToDisplayName()">@ScopeEmoji(_storedGoal.Scope) @_storedGoal.Scope.ToDisplayName()</span>
                }

                @* Branch name — _detail only *@
                @if (_detail is not null && !string.IsNullOrEmpty(_detail.CoderBranch))
                {
                    <span style="font-family:monospace;font-size:0.85rem;color:var(--accent)">⎇ @_detail.CoderBranch</span>
                }

                @* Current phase — _detail only *@
                @if (_detail is not null && !string.IsNullOrEmpty(_detail.CurrentPhase))
                {
                    <span style="color:var(--text-muted)">Phase: <strong style="color:var(--text)">@_detail.CurrentPhase</strong></span>
                }

                @* Current iteration — _detail only *@
                @if (_detail is not null && _detail.CurrentIteration > 0)
                {
                    <span style="color:var(--text-muted)">Iteration: <strong style="color:var(--text)">@_detail.CurrentIteration</strong></span>
                }

                @* Stored iterations count — _storedGoal only *@
                @if (_storedGoal is not null && _storedGoal.Iterations.HasValue)
                {
                    <span style="color:var(--text-muted)">Iterations: <strong style="color:var(--text)">@_storedGoal.Iterations</strong></span>
                }
            </div>

            <div class="goal-detail-meta-row" style="font-size:0.8rem;color:var(--text-muted)">
                @* Created *@
                @if (_detail is not null)
                {
                    <span>Created: @_detail.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                }
                else if (_storedGoal is not null)
                {
                    <span>Created: @_storedGoal.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                }

                @* Started — _storedGoal only *@
                @if (_storedGoal is not null && _storedGoal.StartedAt.HasValue)
                {
                    <span style="margin-left:0.75rem">Started: @_storedGoal.StartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                }

                @* Completed *@
                @if (_detail is not null && _detail.CompletedAt.HasValue)
                {
                    <span style="margin-left:0.75rem">Completed: @_detail.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                }
                else if (_storedGoal is not null && _storedGoal.CompletedAt.HasValue)
                {
                    <span style="margin-left:0.75rem">Completed: @_storedGoal.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                }

                @* Total duration — _storedGoal only *@
                @if (_storedGoal is not null && _storedGoal.TotalDurationSeconds.HasValue)
                {
                    <span style="margin-left:0.75rem">Total: @FormatTotalDuration(_storedGoal.TotalDurationSeconds.Value)</span>
                }

                @* Active task — _detail only *@
                @if (_detail is not null && _detail.ActiveTaskId is not null)
                {
                    <span style="margin-left:0.75rem">Task: <code>@Truncate(_detail.ActiveTaskId, 20)</code></span>
                }

                @* Merge commit *@
                @if (_detail is not null && !string.IsNullOrEmpty(_detail.MergeCommitHash))
                {
                    var hashes = _detail.MergeCommitHash!.Split(',');
                    var commitHash = hashes[0];
                    var shortHash = commitHash[..7];
                    @if (!string.IsNullOrEmpty(_detail.RepositoryUrl))
                    {
                        var commitUrl = $"{_detail.RepositoryUrl}/commit/{commitHash}";
                        <span style="margin-left:0.75rem;display:inline-flex;align-items:center;gap:0.5rem;">
                            🔗 <a href="@commitUrl" target="_blank" style="font-family:monospace;color:var(--accent)">@shortHash</a>
                        </span>
                    }
                    else
                    {
                        <span style="margin-left:0.75rem;font-family:monospace;font-size:0.85rem;color:var(--accent)">🔗 @shortHash</span>
                    }
                }
                else if (_storedGoal is not null && !string.IsNullOrEmpty(_storedGoal.MergeCommitHash))
                {
                    var hashes = _storedGoal.MergeCommitHash!.Split(',');
                    var commitHash = hashes[0];
                    var shortHash = commitHash[..7];
                    var storedRepoUrl = State.GetRepositoryUrl(_storedGoal);
                    @if (!string.IsNullOrEmpty(storedRepoUrl))
                    {
                        var commitUrl = $"{storedRepoUrl}/commit/{commitHash}";
                        <span style="margin-left:0.75rem;display:inline-flex;align-items:center;gap:0.5rem;">
                            🔗 <a href="@commitUrl" target="_blank" style="font-family:monospace;color:var(--accent)">@shortHash</a>
                        </span>
                    }
                    else
                    {
                        <span style="margin-left:0.75rem;font-family:monospace;font-size:0.85rem;color:var(--accent)">🔗 @shortHash</span>
                    }
                }
            </div>

            @* Release assignment *@
            @{
                var releaseId = _goalReleaseId;
            }
            @if (!string.IsNullOrEmpty(releaseId))
            {
                <div style="margin-top:0.25rem;font-size:0.85rem">
                    📦 Release: <a href="/releases/@Uri.EscapeDataString(releaseId)" style="color:var(--accent);text-decoration:none;font-weight:500">@releaseId</a>
                </div>
            }
            else if ((_detail?.Status == GoalStatus.Completed || _storedGoal?.Status == GoalStatus.Completed) && _planningReleases.Count > 0)
            {
                <div style="margin-top:0.25rem;font-size:0.85rem;display:flex;align-items:center;gap:0.5rem">
                    <span style="color:var(--text-muted)">📦 Assign to release:</span>
                    <select @bind="_selectedReleaseId"
                            style="padding:0.3rem 0.6rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem">
                        <option value="">— select —</option>
                        @foreach (var r in _planningReleases)
                        {
                            <option value="@r.Id">@r.Tag</option>
                        }
                    </select>
                    <button class="approve-btn" style="font-size:0.8rem;padding:0.25rem 0.6rem"
                            @onclick="AssignToRelease" disabled="@string.IsNullOrEmpty(_selectedReleaseId)">Assign</button>
                    @if (!string.IsNullOrEmpty(_releaseAssignError))
                    {
                        <span class="error-msg">@_releaseAssignError</span>
                    }
                </div>
            }
        </div>

        @* ===== BODY — left (description/notes) + right (iterations) ===== *@
        @{
            var hasDetailIterations = _detail?.Iterations.Count > 0;
            var hasStoredIterations = _storedIterations.Count > 0;
            var hasAnyIterations = hasDetailIterations || hasStoredIterations;
        }
        <div class="goal-detail-body">
            @* LEFT PANEL *@
            <div class="goal-detail-left @(hasAnyIterations ? "" : "full-width")">
                @* Description *@
                @if (_detail is not null)
                {
                    <div class="card" style="margin-bottom:0.75rem">
                        <div class="label">Description</div>
                        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(_detail.Description))</div>
                    </div>
                }
                else if (_storedGoal is not null)
                {
                    <div class="card" style="margin-bottom:0.75rem">
                        <div class="label">Description</div>
                        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(_storedGoal.Description))</div>
                    </div>
                }

                @* Dependencies *@
                @if (_detail is not null && _detail.DependsOn.Count > 0)
                {
                    <div class="card goal-dependencies" style="margin-bottom:0.75rem">
                        <div class="label">Dependencies</div>
                        <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.9rem">
                            @foreach (var depId in _detail.DependsOn)
                            {
                                <li>
                                    <a href="/goals/@depId" class="goal-link">@depId</a>
                                    @if (_dependencyStatuses.TryGetValue(depId, out var depStatus))
                                    {
                                        <span style="margin-left:0.4rem">@GetStatusIcon(depStatus)</span>
                                    }
                                    else
                                    {
                                        <span style="margin-left:0.4rem">@GetStatusIcon(null)</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
                else if (_storedGoal is not null && _storedGoal.DependsOn.Count > 0)
                {
                    <div class="card goal-dependencies" style="margin-bottom:0.75rem">
                        <div class="label">Dependencies</div>
                        <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.9rem">
                            @foreach (var depId in _storedGoal.DependsOn)
                            {
                                <li>
                                    <a href="/goals/@depId" class="goal-link">@depId</a>
                                    @if (_dependencyStatuses.TryGetValue(depId, out var depStatus2))
                                    {
                                        <span style="margin-left:0.4rem">@GetStatusIcon(depStatus2)</span>
                                    }
                                    else
                                    {
                                        <span style="margin-left:0.4rem">@GetStatusIcon(null)</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }

                @* Notes *@
                @if (_detail is not null && _detail.Notes.Count > 0)
                {
                    <div class="card" style="margin-bottom:0.75rem">
                        <div class="label">Notes</div>
                        <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.85rem">
                            @foreach (var note in _detail.Notes)
                            {
                                <li style="color:var(--text-muted)">@note</li>
                            }
                        </ul>
                    </div>
                }
                else if (_storedGoal is not null && _storedGoal.Notes.Count > 0)
                {
                    <div class="card" style="margin-bottom:0.75rem">
                        <div class="label">Notes</div>
                        <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.85rem">
                            @foreach (var note in _storedGoal.Notes)
                            {
                                <li style="color:var(--text-muted)">@note</li>
                            }
                        </ul>
                    </div>
                }

                @* Failure reason — _storedGoal only *@
                @if (_storedGoal is not null && !string.IsNullOrEmpty(_storedGoal.FailureReason))
                {
                    <div class="failure-callout" style="margin-bottom:0.75rem">
                        <div class="label">Failure Reason</div>
                        <div style="margin-top:0.25rem">@_storedGoal.FailureReason</div>
                    </div>
                }

                @* Phase durations — _storedGoal only *@
                @if (_storedGoal is not null && _storedGoal.PhaseDurations is { Count: > 0 })
                {
                    <div class="card" style="margin-bottom:0.75rem">
                        <div class="label">Phase Durations</div>
                        <table style="margin-top:0.5rem;max-width:400px">
                            <thead><tr><th>Phase</th><th>Duration</th></tr></thead>
                            <tbody>
                                @foreach (var kvp in _storedGoal.PhaseDurations)
                                {
                                    <tr>
                                        <td>@kvp.Key</td>
                                        <td style="color:var(--text-muted)">@FormatDuration(kvp.Value)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* RIGHT PANEL — iterations *@
            @if (hasAnyIterations)
            {
                <div class="goal-detail-right">
                    @* _detail iterations *@
                    @if (_detail is not null && _detail.Iterations.Count > 0)
                    {
                        var iterations = _detail.Iterations;
                        <div class="iter-tabs">
                            @foreach (var iter in iterations)
                            {
                                <button class="@GetTabClass(iter)"
                                        selected="@(GetActiveIteration() == iter.Number)"
                                        @onclick="() => SelectIteration(iter.Number)">
                                    Iter @iter.Number
                                </button>
                            }
                        </div>

                        @foreach (var iter in iterations)
                        {
                            @if (GetActiveIteration() == iter.Number)
                            {
                                <div class="phase-bar" style="margin-bottom:0.5rem">
                                    @foreach (var phase in iter.Phases)
                                    {
                                        var phaseKey = $"{iter.Number}-{phase.Name}";
                                        <button class="phase-box @phase.Status @(_selectedPhase == phaseKey ? "selected" : "")"
                                                @onclick="() => TogglePhase(phaseKey)">
                                            <span class="phase-box-icon">@PhaseIcon(phase.Status)</span>
                                            @phase.Name
                                            @if (phase.DurationSeconds.HasValue)
                                            {
                                                <span class="phase-box-duration">@FormatDuration(phase.DurationSeconds.Value)</span>
                                            }
                                        </button>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(iter.PlanReason))
                                {
                                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.5rem;font-style:italic">
                                        🗋 @iter.PlanReason
                                    </div>
                                }

                                @foreach (var phase in iter.Phases)
                                {
                                    var phaseKey = $"{iter.Number}-{phase.Name}";
                                    @if (_selectedPhase == phaseKey)
                                    {
                                        <div class="phase-detail">
                                            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem">
                                                <strong>@phase.Name</strong>
                                                <span class="badge @PhaseBadge(phase.Status)">@phase.Status</span>
                                                @if (!string.IsNullOrEmpty(phase.Verdict))
                                                {
                                                    <span style="color:var(--text-muted)">Verdict: @phase.Verdict</span>
                                                }
                                                @if (phase.DurationSeconds.HasValue)
                                                {
                                                    <span style="color:var(--text-muted)">Duration: @FormatDuration(phase.DurationSeconds.Value)</span>
                                                }
                                                <button class="phase-detail-close" @onclick="ClearSelectedPhase" title="Close">✕</button>
                                            </div>

                                            @if (phase.TotalTests > 0)
                                            {
                                                <table style="margin-bottom:0.75rem;max-width:400px">
                                                    <thead><tr><th>Metric</th><th>Value</th></tr></thead>
                                                    <tbody>
                                                        <tr><td>Build</td><td style="color:@(phase.BuildSuccess ? "var(--green)" : "var(--red)")">@(phase.BuildSuccess ? "✓ Success" : "✗ Failed")</td></tr>
                                                        <tr><td>Total Tests</td><td>@phase.TotalTests</td></tr>
                                                        <tr><td>Passed</td><td style="color:var(--green)">@phase.PassedTests</td></tr>
                                                        <tr><td>Failed</td><td style="color:@(phase.FailedTests > 0 ? "var(--red)" : "var(--text)")">@phase.FailedTests</td></tr>
                                                        @if (phase.CoveragePercent > 0)
                                                        {
                                                            <tr><td>Coverage</td><td>@($"{phase.CoveragePercent:F1}%")</td></tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }

                                            @if (!string.IsNullOrEmpty(phase.ReviewVerdict))
                                            {
                                                <div style="margin-bottom:0.5rem">
                                                    <span class="label">Review:</span>
                                                    <span class="badge @ReviewBadge(phase.ReviewVerdict)">@phase.ReviewVerdict</span>
                                                    @if (phase.ReviewIssuesFound > 0)
                                                    {
                                                        <span style="margin-left:0.5rem;color:var(--text-muted)">@phase.ReviewIssuesFound issue(s)</span>
                                                    }
                                                </div>
                                            }

                                            @if (phase.Issues.Count > 0)
                                            {
                                                <div style="margin-bottom:0.75rem">
                                                    <div class="label" style="margin-bottom:0.25rem">Issues</div>
                                                    <ul style="margin:0 0 0 1.2rem;font-size:0.85rem">
                                                        @foreach (var issue in phase.Issues)
                                                        {
                                                            <li style="color:var(--red)">@issue</li>
                                                        }
                                                    </ul>
                                                </div>
                                            }

                                            @if (phase.ProgressReports.Count > 0)
                                            {
                                                <div style="margin-bottom:0.75rem">
                                                    <div class="label" style="margin-bottom:0.25rem">Progress Reports</div>
                                                    <table style="font-size:0.85rem">
                                                        <thead><tr><th>Time</th><th>Worker</th><th>Status</th><th>Details</th></tr></thead>
                                                        <tbody>
                                                            @foreach (var rpt in phase.ProgressReports)
                                                            {
                                                                <tr>
                                                                    <td style="white-space:nowrap;color:var(--text-muted)">@rpt.Timestamp.ToString("HH:mm:ss")</td>
                                                                    <td style="font-family:monospace;font-size:0.85rem">@Truncate(rpt.WorkerId, 12)</td>
                                                                    <td><span class="badge badge-blue">@rpt.Status</span></td>
                                                                    <td>@Truncate(rpt.Details, 200)</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }

                                            @if (phase.Clarifications.Count > 0)
                                            {
                                                <div style="margin-bottom:0.75rem">
                                                    <div class="label" style="margin-bottom:0.5rem">Clarifications (@phase.Clarifications.Count)</div>
                                                    @foreach (var clarification in phase.Clarifications)
                                                    {
                                                        <div style="margin-bottom:0.75rem;padding:0.5rem 0.75rem;border-left:3px solid var(--yellow);background:rgba(227,179,65,0.08);border-radius:4px">
                                                            <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.25rem">
                                                                @clarification.Timestamp.ToString("HH:mm:ss") UTC
                                                            </div>
                                                            <div style="margin-bottom:0.35rem"><strong>Q:</strong> @clarification.Question</div>
                                                            <div style="margin-bottom:0.25rem"><strong>A:</strong> @clarification.Answer</div>
                                                            <div style="font-size:0.75rem;color:var(--text-muted)">answered by: @clarification.AnsweredBy</div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(phase.WorkerOutput))
                                            {
                                                <div style="margin-bottom:0.75rem">
                                                    <div class="label" style="margin-bottom:0.5rem">Worker Output (@phase.RoleName)</div>
                                                    <div class="chat-msg-content">@((MarkupString)RenderMarkdown(phase.WorkerOutput))</div>
                                                </div>
                                            }

                                            @if (phase.Name == "Planning")
                                            {
                                                @if (!string.IsNullOrEmpty(iter.PlanningBrainResponse))
                                                {
                                                    <details class="collapsible-output">
                                                        <summary>Planning Response</summary>
                                                        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(iter.PlanningBrainResponse))</div>
                                                    </details>
                                                }
                                                @if (!string.IsNullOrEmpty(iter.PlanningBrainPrompt))
                                                {
                                                    <details class="collapsible-output">
                                                        <summary style="color:var(--text-muted)">Planning Prompt</summary>
                                                        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(iter.PlanningBrainPrompt))</div>
                                                    </details>
                                                }
                                            }
                                            @if (!string.IsNullOrEmpty(phase.BrainPrompt))
                                            {
                                                <details class="collapsible-output">
                                                    <summary style="color:var(--text-muted)">Brain Prompt</summary>
                                                    <div class="chat-msg-content">@((MarkupString)RenderMarkdown(phase.BrainPrompt))</div>
                                                </details>
                                            }
                                            @if (!string.IsNullOrEmpty(phase.WorkerPrompt))
                                            {
                                                <details class="collapsible-output">
                                                    <summary>Worker Prompt (@phase.RoleName)</summary>
                                                    <div class="chat-msg-content">@((MarkupString)RenderMarkdown(phase.WorkerPrompt))</div>
                                                </details>
                                            }
                                        </div>
                                    }
                                }
                            }
                        }
                    }

                    @* _storedIterations (from SQLite) *@
                    @if (_storedIterations.Count > 0)
                    {
                        <div class="iter-tabs">
                            @foreach (var iter in _storedIterations)
                            {
                                <button class="iter-tab selected done" @onclick="() => SelectIteration(iter.Iteration)">
                                    Iter @iter.Iteration
                                </button>
                            }
                        </div>

                        @foreach (var iter in _storedIterations)
                        {
                            @if ((_selectedIteration > 0 ? _selectedIteration : _storedIterations.First().Iteration) == iter.Iteration)
                            {
                                <div class="phase-bar" style="margin-bottom:0.5rem">
                                    @foreach (var phase in iter.Phases)
                                    {
                                        <span class="phase-box @(phase.Result == "pass" ? "completed" : phase.Result == "fail" ? "failed" : "skipped")">
                                            <span class="phase-box-icon">@(phase.Result == "pass" ? "✓" : phase.Result == "fail" ? "✗" : "~")</span>
                                            @phase.Name
                                            @if (phase.DurationSeconds > 0)
                                            {
                                                <span class="phase-box-duration">@FormatDuration(phase.DurationSeconds)</span>
                                            }
                                        </span>
                                    }
                                </div>

                                @if (iter.TestCounts is { } tc)
                                {
                                    <div class="iter-summary-cards">
                                        <div class="card">
                                            <div class="label">Tests</div>
                                            <div class="value">@tc.Total</div>
                                        </div>
                                        <div class="card">
                                            <div class="label">Passed</div>
                                            <div class="value" style="color:var(--green)">@tc.Passed</div>
                                        </div>
                                        @if (tc.Failed > 0)
                                        {
                                            <div class="card">
                                                <div class="label">Failed</div>
                                                <div class="value" style="color:var(--red)">@tc.Failed</div>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (iter.Notes.Count > 0)
                                {
                                    <ul style="margin:0 0 0.5rem 1.2rem;font-size:0.85rem">
                                        @foreach (var note in iter.Notes)
                                        {
                                            <li style="color:var(--text-muted)">@note</li>
                                        }
                                    </ul>
                                }
                            }
                        }
                    }
                </div>
            }
        </div>

        @* ===== BOTTOM STRIP — action buttons ===== *@
        <div class="goal-detail-bottom">
            @if (_detail is not null || _storedGoal is not null)
            {
                @* Approve — Draft only *@
                @if (_detail?.Status == GoalStatus.Draft || _storedGoal?.Status == GoalStatus.Draft)
                {
                    <button class="approve-btn" @onclick="ApproveGoal">▶ Approve</button>
                    @if (!string.IsNullOrEmpty(_approveError))
                    {
                        <span class="error-msg">@_approveError</span>
                    }
                }

                @* Revert to Draft — Pending only *@
                @if (_detail?.Status == GoalStatus.Pending || _storedGoal?.Status == GoalStatus.Pending)
                {
                    <button class="revert-btn" style="background:var(--text-muted);color:#fff;border:none;padding:0.4rem 1rem;border-radius:4px;cursor:pointer;font-size:0.9rem" @onclick="RevertToDraft">↩ Revert to Draft</button>
                    @if (!string.IsNullOrEmpty(_revertError))
                    {
                        <span class="error-msg">@_revertError</span>
                    }
                }

                @* Cancel — InProgress or Pending *@
                @if (_detail?.Status == GoalStatus.InProgress || _detail?.Status == GoalStatus.Pending ||
                     _storedGoal?.Status == GoalStatus.InProgress || _storedGoal?.Status == GoalStatus.Pending)
                {
                    <button style="background:var(--red);color:#fff;border:none;padding:0.4rem 1rem;border-radius:4px;cursor:pointer;font-size:0.9rem" @onclick="CancelGoal">⏹ Cancel Goal</button>
                    @if (!string.IsNullOrEmpty(_cancelError))
                    {
                        <span class="error-msg">@_cancelError</span>
                    }
                }

                @* Delete — Draft or Failed *@
                @if ((_detail?.Status == GoalStatus.Draft || _detail?.Status == GoalStatus.Failed) ||
                     (_storedGoal?.Status == GoalStatus.Draft || _storedGoal?.Status == GoalStatus.Failed))
                {
                    <button style="background:var(--red);color:#fff;border:none;padding:0.4rem 1rem;border-radius:4px;cursor:pointer;font-size:0.9rem"
                        @onclick="DeleteCurrentGoal">🗑️ Delete Goal</button>
                    @if (!string.IsNullOrEmpty(_deleteError))
                    {
                        <span class="error-msg">@_deleteError</span>
                    }
                }
            }
        </div>
    </div>
}
else
{
    <p>Goal not found.</p>
}

@code {
    [Parameter] public string GoalId { get; set; } = "";

    private GoalDetailInfo? _detail;
    private Goal? _storedGoal;
    private IReadOnlyList<IterationSummary> _storedIterations = [];
    private IReadOnlyList<ProgressEntry> _progress = [];
    private int _selectedIteration; // 0 = auto-select
    private string? _selectedPhase;
    private string? _approveError;
    private string? _revertError;
    private string? _cancelError;
    private string? _deleteError;
    private Dictionary<string, GoalStatus> _dependencyStatuses = new();
    private List<Release> _planningReleases = [];
    private string _selectedReleaseId = "";
    private string? _releaseAssignError;
    private string? _goalReleaseId;

    protected override void OnInitialized()
    {
        Refresh();
        State.OnStateChanged += RefreshState;
    }

    protected override void OnParametersSet()
    {
        PageHeader.SetTitle($"🎯 Goal: {GoalId}");
        PageHeader.SetBack("/goals");
        Refresh();
    }

    private void Refresh()
    {
        _detail = State.GetGoalDetail(GoalId);
        _progress = State.GetProgressForGoal(GoalId);

        // Fallback: load from SQLite for completed/failed goals not in active pipelines
        if (_detail is null)
        {
            _storedGoal = GoalStore.GetGoalAsync(GoalId).GetAwaiter().GetResult();
            _storedIterations = _storedGoal is not null
                ? GoalStore.GetIterationsAsync(GoalId).GetAwaiter().GetResult()
                : [];
        }
        else
        {
            _storedGoal = null;
            _storedIterations = [];
        }

        // Resolve release ID — load from store for _detail branch (pipeline goals don't carry ReleaseId)
        if (_detail is not null)
        {
            var liveGoal = GoalStore.GetGoalAsync(GoalId).GetAwaiter().GetResult();
            _goalReleaseId = liveGoal?.ReleaseId;
        }
        else
        {
            _goalReleaseId = _storedGoal?.ReleaseId;
        }

        // Pre-fetch dependency statuses for display
        var depIds = _detail?.DependsOn ?? _storedGoal?.DependsOn ?? [];
        if (depIds.Count > 0)
        {
            var statuses = new Dictionary<string, GoalStatus>();
            foreach (var depId in depIds)
            {
                var depDetail = State.GetGoalDetail(depId);
                if (depDetail is not null)
                {
                    statuses[depId] = depDetail.Status;
                }
                else
                {
                    var stored = GoalStore.GetGoalAsync(depId).GetAwaiter().GetResult();
                    if (stored is not null)
                        statuses[depId] = stored.Status;
                }
            }
            _dependencyStatuses = statuses;
        }
        else
        {
            _dependencyStatuses = new();
        }

        // Load Planning releases for release-assignment dropdown (shown when goal is Completed and unassigned)
        var goalStatus = _detail?.Status ?? _storedGoal?.Status;
        if (goalStatus == GoalStatus.Completed && string.IsNullOrEmpty(_goalReleaseId))
        {
            var allReleases = GoalStore.GetReleasesAsync().GetAwaiter().GetResult();
            var goalRepos = _detail?.RepositoryNames ?? _storedGoal?.RepositoryNames ?? [];
            _planningReleases = allReleases
                .Where(r => r.Status == ReleaseStatus.Planning)
                .Where(r => r.RepositoryNames.Count == 0 ||
                            goalRepos.Count == 0 ||
                            r.RepositoryNames.Intersect(goalRepos, StringComparer.OrdinalIgnoreCase).Any())
                .ToList();
        }
        else
        {
            _planningReleases = [];
        }
    }

    private void RefreshState() => InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private void TogglePhase(string phaseKey)
    {
        _selectedPhase = _selectedPhase == phaseKey ? null : phaseKey;
    }

    private void SelectIteration(int number)
    {
        _selectedIteration = number;
        _selectedPhase = null; // reset phase selection when switching tabs
    }

    private void ClearSelectedPhase()
    {
        _selectedPhase = null;
    }

    private int GetActiveIteration()
    {
        if (_selectedIteration > 0) return _selectedIteration;
        var current = _detail?.Iterations.FirstOrDefault(i => i.IsCurrent);
        return current?.Number ?? _detail?.Iterations.LastOrDefault()?.Number ?? 0;
    }

    private static string GetTabClass(IterationViewInfo iter) => iter switch
    {
        { IsCurrent: true } => "iter-tab selected current",
        _ when iter.Phases.Any(p => p.Status == "failed") => "iter-tab selected failed",
        _ => "iter-tab selected done",
    };

    private static string StatusBadge(GoalStatus s) => s switch
    {
        GoalStatus.Completed => "badge-green",
        GoalStatus.Failed => "badge-red",
        GoalStatus.InProgress => "badge-blue",
        GoalStatus.Pending => "badge-yellow",
        GoalStatus.Draft => "badge-muted",
        _ => "badge-muted",
    };

    private static string PhaseBadge(string status) => status switch
    {
        "completed" => "badge-green",
        "failed" => "badge-red",
        "active" => "badge-blue",
        "waiting" => "badge-yellow",
        _ => "badge-muted",
    };

    private static string PhaseIcon(string status) => status switch
    {
        "completed" => "✓",
        "failed" => "✗",
        "active" => "●",
        "waiting" => "💬",
        "pending" => "○",
        "skipped" => "~",
        _ => "○",
    };

    private static string ReviewBadge(string? verdict) =>
        string.Equals(verdict, "Approve", StringComparison.OrdinalIgnoreCase) ? "badge-green" : "badge-red";

    private static string ScopeEmoji(GoalScope scope) => scope switch
    {
        GoalScope.Patch => "🔧",
        GoalScope.Feature => "✨",
        GoalScope.Breaking => "💥",
        _ => throw new InvalidOperationException($"Unknown GoalScope: {scope}"),
    };

    private static string FormatDuration(double seconds) =>
        seconds >= 60 ? $"{seconds / 60:F1}m" : $"{seconds:F0}s";

    private static string FormatTotalDuration(double seconds)
    {
        if (seconds >= 3600) return $"{seconds / 3600:F1}h";
        if (seconds >= 60) return $"{seconds / 60:F1}m";
        return $"{seconds:F0}s";
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static readonly MarkdownPipeline MdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static string RenderMarkdown(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return Markdown.ToHtml(content, MdPipeline);
    }

    private static string GetStatusIcon(GoalStatus? status) => status switch
    {
        GoalStatus.Completed => "✅",
        GoalStatus.Pending => "⏳",
        GoalStatus.InProgress => "🔄",
        GoalStatus.Failed => "❌",
        _ => "❓",
    };

    public void Dispose() => State.OnStateChanged -= RefreshState;

    private async Task ApproveGoal()
    {
        _approveError = null;
        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { status = "Pending" }),
            System.Text.Encoding.UTF8,
            "application/json");
        var response = await HttpClient.PatchAsync($"/api/goals/{GoalId}/status", body);
        if (response.IsSuccessStatusCode)
        {
            Refresh();
            // Update local state if loaded from SQLite (no active pipeline)
            if (_storedGoal is not null)
                _storedGoal.Status = GoalStatus.Pending;
            StateHasChanged();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            _approveError = $"Error {(int)response.StatusCode}: {errorContent}";
        }
    }

    private async Task RevertToDraft()
    {
        _revertError = null;
        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { status = "Draft" }),
            System.Text.Encoding.UTF8,
            "application/json");
        var response = await HttpClient.PatchAsync($"/api/goals/{GoalId}/status", body);
        if (response.IsSuccessStatusCode)
        {
            Refresh();
            // Update local state if loaded from SQLite (no active pipeline)
            if (_storedGoal is not null)
                _storedGoal.Status = GoalStatus.Draft;
            StateHasChanged();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            _revertError = $"Error {(int)response.StatusCode}: {errorContent}";
        }
    }

    private async Task CancelGoal()
    {
        _cancelError = null;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to cancel goal '{GoalId}'?");
        if (!confirmed) return;

        var response = await HttpClient.PostAsync($"/api/goals/{GoalId}/cancel", null);
        if (response.IsSuccessStatusCode)
        {
            Refresh();
            StateHasChanged();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            _cancelError = $"Error {(int)response.StatusCode}: {errorContent}";
            StateHasChanged();
        }
    }

    private async Task DeleteCurrentGoal()
    {
        _deleteError = null;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete goal '{GoalId}'?");
        if (!confirmed) return;

        var response = await HttpClient.DeleteAsync($"/api/goals/{GoalId}");
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/goals");
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            _deleteError = $"Error {(int)response.StatusCode}: {errorContent}";
            StateHasChanged();
        }
    }

    private async Task AssignToRelease()
    {
        _releaseAssignError = null;
        if (string.IsNullOrEmpty(_selectedReleaseId)) return;

        var body = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(new { releaseId = _selectedReleaseId }),
            System.Text.Encoding.UTF8,
            "application/json");
        var response = await HttpClient.PatchAsync($"/api/goals/{GoalId}/release", body);
        if (response.IsSuccessStatusCode)
        {
            // Update local state
            if (_storedGoal is not null)
                _storedGoal.ReleaseId = _selectedReleaseId;
            _goalReleaseId = _selectedReleaseId;
            _selectedReleaseId = "";
            _planningReleases = [];
            StateHasChanged();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            _releaseAssignError = $"Error {(int)response.StatusCode}: {errorContent}";
        }
    }
}
