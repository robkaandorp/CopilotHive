@page "/goals/{GoalId}"
@using CopilotHive.Dashboard
@using CopilotHive.Goals
@implements IDisposable
@inject DashboardStateService State

<h1>Goal: @GoalId</h1>

@if (_goal is not null)
{
    <div class="card" style="margin-bottom:1rem">
        <div class="label">Description</div>
        <div>@_goal.Description</div>
        <div style="margin-top:0.5rem">
            <span class="badge @StatusBadge(EffectiveStatus)">@EffectiveStatus</span>
            <span style="color:var(--text-muted);margin-left:0.5rem">Priority: @_goal.Priority</span>
        </div>
    </div>

    @if (_pipeline is not null)
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label">Current Progress</div>
            <div style="margin-top:0.5rem">
                <PhaseTimeline Phase="@_pipeline.Phase" Phases="@_pipeline.Phases" />
            </div>
            <div style="margin-top:0.75rem;display:flex;gap:2rem">
                <div><span class="label">Iteration:</span> @_pipeline.Iteration</div>
                <div><span class="label">Tests:</span> @_pipeline.PassedTests/@_pipeline.TotalTests</div>
                <div><span class="label">Coverage:</span> @(_pipeline.CoveragePercent > 0 ? $"{_pipeline.CoveragePercent:F1}%" : "—")</div>
            </div>
            @if (_pipeline.ActiveTaskId is not null)
            {
                <div style="margin-top:0.5rem;color:var(--text-muted);font-size:0.85rem">
                    Active task: @_pipeline.ActiveTaskId
                </div>
            }
        </div>
    }

    <h2 style="margin-top:1.5rem">Progress Reports</h2>
    @if (_progress.Count > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Worker</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _progress)
                {
                    <tr>
                        <td style="white-space:nowrap;color:var(--text-muted)">@entry.Timestamp.ToString("HH:mm:ss")</td>
                        <td style="font-family:monospace;font-size:0.85rem">
                            <a href="/workers/@entry.WorkerId" style="color:var(--accent);text-decoration:none">@Truncate(entry.WorkerId, 12)</a>
                        </td>
                        <td><span class="badge badge-blue">@entry.Status</span></td>
                        <td style="font-size:0.85rem">@Truncate(entry.Details, 200)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:var(--text-muted)">No progress reports for this goal yet.</p>
    }
}
else
{
    <p style="color:var(--text-muted)">Goal not found.</p>
}

@code {
    [Parameter] public string GoalId { get; set; } = "";

    private Goal? _goal;
    private PipelineInfo? _pipeline;
    private IReadOnlyList<ProgressEntry> _progress = [];

    // The Goal object from pipelines may be stale (snapshot at dispatch time).
    // Derive status from the pipeline phase which is always current.
    private GoalStatus EffectiveStatus => _pipeline?.Phase switch
    {
        "Completed" or "Done" => GoalStatus.Completed,
        "Failed" => GoalStatus.Failed,
        "Planning" or "Coding" or "Testing" or "Review"
            or "DocWriting" or "Improve" or "Merging" => GoalStatus.InProgress,
        _ => _goal?.Status ?? GoalStatus.Pending,
    };

    protected override void OnInitialized()
    {
        Refresh();
        State.OnStateChanged += RefreshState;
    }

    protected override void OnParametersSet() => Refresh();

    private void Refresh()
    {
        var snap = State.GetSnapshot();
        _goal = snap.Goals.FirstOrDefault(g => g.Id == GoalId);
        _pipeline = snap.Pipelines.FirstOrDefault(p => p.GoalId == GoalId);
        _progress = State.GetProgressForGoal(GoalId);
    }

    private void RefreshState() => InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private static string StatusBadge(GoalStatus s) => s switch
    {
        GoalStatus.Completed => "badge-green",
        GoalStatus.Failed => "badge-red",
        GoalStatus.InProgress => "badge-blue",
        GoalStatus.Pending => "badge-yellow",
        _ => "badge-muted",
    };

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    public void Dispose() => State.OnStateChanged -= RefreshState;
}
