@page "/goals/{GoalId}"
@using CopilotHive.Dashboard
@using CopilotHive.Goals
@using CopilotHive.Orchestration
@using Markdig
@implements IDisposable
@inject DashboardStateService State
@inject IGoalStore GoalStore
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HttpClient HttpClient

<h1>Goal: @GoalId</h1>

@if (_detail is not null)
{
    <!-- Header -->
    <div class="card" style="margin-bottom:1rem">
        <div class="label">Description</div>
        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(_detail.Description))</div>
        <div style="margin-top:0.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <span class="badge @StatusBadge(_detail.Status)">@_detail.Status</span>
            <span style="color:var(--text-muted)">Priority: @_detail.Priority</span>
            @if (!string.IsNullOrEmpty(_detail.CoderBranch))
            {
                <span style="font-family:monospace;font-size:0.85rem;color:var(--accent)">⎇ @_detail.CoderBranch</span>
            }
            @if (!string.IsNullOrEmpty(_detail.CurrentPhase))
            {
                <span style="color:var(--text-muted)">Phase: <strong style="color:var(--text)">@_detail.CurrentPhase</strong></span>
            }
            @if (_detail.CurrentIteration > 0)
            {
                <span style="color:var(--text-muted)">Iteration: <strong style="color:var(--text)">@_detail.CurrentIteration</strong></span>
            }
        </div>
        <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--text-muted)">
            Created: @_detail.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC
            @if (_detail.CompletedAt.HasValue)
            {
                <span style="margin-left:1rem">Completed: @_detail.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            }
            @if (_detail.ActiveTaskId is not null)
            {
                <span style="margin-left:1rem">Task: <code>@Truncate(_detail.ActiveTaskId, 20)</code></span>
            }
        </div>
    </div>

    @if (_detail.Notes.Count > 0)
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label">Notes</div>
            <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.85rem">
                @foreach (var note in _detail.Notes)
                {
                    <li style="color:var(--text-muted)">@note</li>
                }
            </ul>
        </div>
    }

    <!-- Iteration Timeline -->
    <h2 style="margin-top:1.5rem">Iterations</h2>
    @if (_detail.Iterations.Count > 0)
    {
        @for (int i = 0; i < _detail.Iterations.Count; i++)
        {
            var iteration = _detail.Iterations[i];
            var idx = i;
            var hasFailed = iteration.Phases.Any(p => p.Status == "failed");

            <div class="iteration-section">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem">
                    <strong>Iteration @iteration.Number</strong>
                    @if (iteration.IsCurrent)
                    {
                        <span class="badge badge-blue">current</span>
                    }
                    else if (hasFailed)
                    {
                        <span class="badge badge-red">retry</span>
                    }
                    else
                    {
                        <span class="badge badge-green">done</span>
                    }
                </div>

                <div class="phase-bar" style="margin-bottom:0.5rem">
                    @foreach (var phase in iteration.Phases)
                    {
                        var phaseKey = $"{iteration.Number}-{phase.Name}";
                        <button class="phase-box @phase.Status" @onclick="() => TogglePhase(phaseKey)">
                            <span class="phase-box-icon">@PhaseIcon(phase.Status)</span>
                            @phase.Name
                            @if (phase.DurationSeconds.HasValue)
                            {
                                <span class="phase-box-duration">@FormatDuration(phase.DurationSeconds.Value)</span>
                            }
                        </button>
                    }
                </div>

                @foreach (var phase in iteration.Phases)
                {
                    var phaseKey = $"{iteration.Number}-{phase.Name}";
                    @if (_selectedPhase == phaseKey)
                    {
                        <div class="phase-detail">
                            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem">
                                <strong>@phase.Name</strong>
                                <span class="badge @PhaseBadge(phase.Status)">@phase.Status</span>
                                @if (!string.IsNullOrEmpty(phase.Verdict))
                                {
                                    <span style="color:var(--text-muted)">Verdict: @phase.Verdict</span>
                                }
                                @if (phase.DurationSeconds.HasValue)
                                {
                                    <span style="color:var(--text-muted)">Duration: @FormatDuration(phase.DurationSeconds.Value)</span>
                                }
                            </div>

                            @if (phase.TotalTests > 0)
                            {
                                <table style="margin-bottom:0.75rem;max-width:400px">
                                    <thead><tr><th>Metric</th><th>Value</th></tr></thead>
                                    <tbody>
                                        <tr><td>Build</td><td style="color:@(phase.BuildSuccess ? "var(--green)" : "var(--red)")">@(phase.BuildSuccess ? "✓ Success" : "✗ Failed")</td></tr>
                                        <tr><td>Total Tests</td><td>@phase.TotalTests</td></tr>
                                        <tr><td>Passed</td><td style="color:var(--green)">@phase.PassedTests</td></tr>
                                        <tr><td>Failed</td><td style="color:@(phase.FailedTests > 0 ? "var(--red)" : "var(--text)")">@phase.FailedTests</td></tr>
                                        @if (phase.CoveragePercent > 0)
                                        {
                                            <tr><td>Coverage</td><td>@($"{phase.CoveragePercent:F1}%")</td></tr>
                                        }
                                    </tbody>
                                </table>
                            }

                            @if (!string.IsNullOrEmpty(phase.ReviewVerdict))
                            {
                                <div style="margin-bottom:0.5rem">
                                    <span class="label">Review:</span>
                                    <span class="badge @ReviewBadge(phase.ReviewVerdict)">@phase.ReviewVerdict</span>
                                    @if (phase.ReviewIssuesFound > 0)
                                    {
                                        <span style="margin-left:0.5rem;color:var(--text-muted)">@phase.ReviewIssuesFound issue(s)</span>
                                    }
                                </div>
                            }

                            @if (phase.Issues.Count > 0)
                            {
                                <div style="margin-bottom:0.75rem">
                                    <div class="label" style="margin-bottom:0.25rem">Issues</div>
                                    <ul style="margin:0 0 0 1.2rem;font-size:0.85rem">
                                        @foreach (var issue in phase.Issues)
                                        {
                                            <li style="color:var(--red)">@issue</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (phase.ProgressReports.Count > 0)
                            {
                                <div style="margin-bottom:0.75rem">
                                    <div class="label" style="margin-bottom:0.25rem">Progress Reports</div>
                                    <table style="font-size:0.85rem">
                                        <thead><tr><th>Time</th><th>Worker</th><th>Status</th><th>Details</th></tr></thead>
                                        <tbody>
                                            @foreach (var rpt in phase.ProgressReports)
                                            {
                                                <tr>
                                                    <td style="white-space:nowrap;color:var(--text-muted)">@rpt.Timestamp.ToString("HH:mm:ss")</td>
                                                    <td style="font-family:monospace;font-size:0.85rem">@Truncate(rpt.WorkerId, 12)</td>
                                                    <td><span class="badge badge-blue">@rpt.Status</span></td>
                                                    <td>@Truncate(rpt.Details, 200)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(phase.WorkerOutput))
                            {
                                <details class="collapsible-output">
                                    <summary>Worker Output (@phase.RoleName)</summary>
                                    <pre>@phase.WorkerOutput</pre>
                                </details>
                            }
                        </div>
                    }
                }

                @if (hasFailed && idx < _detail.Iterations.Count - 1)
                {
                    <div class="iteration-arrow">↻ Retry — iteration failed, advancing to next</div>
                }
            </div>
        }
    }
    else
    {
        <p style="color:var(--text-muted)">No iterations yet — goal is pending.</p>
    }

    <!-- Progress Reports -->
    <h2 style="margin-top:1.5rem">Progress Reports</h2>
    @if (_progress.Count > 0)
    {
        <table>
            <thead>
                <tr><th>Time</th><th>Worker</th><th>Status</th><th>Details</th></tr>
            </thead>
            <tbody>
                @foreach (var entry in _progress)
                {
                    <tr>
                        <td style="white-space:nowrap;color:var(--text-muted)">@entry.Timestamp.ToString("HH:mm:ss")</td>
                        <td style="font-family:monospace;font-size:0.85rem">
                            <a href="/workers/@entry.WorkerId" style="color:var(--accent);text-decoration:none">@Truncate(entry.WorkerId, 12)</a>
                        </td>
                        <td><span class="badge badge-blue">@entry.Status</span></td>
                        <td style="font-size:0.85rem">@Truncate(entry.Details, 200)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:var(--text-muted)">No progress reports for this goal yet.</p>
    }

    <!-- Conversation Log -->
    @if (_detail.Conversation.Count > 0)
    {
        <h2 style="margin-top:1.5rem">Brain Conversation</h2>
        <details style="margin-bottom:1rem">
            <summary style="cursor:pointer;color:var(--accent)">Show @_detail.Conversation.Count message(s)</summary>
            <div class="log-view" style="margin-top:0.5rem">
                @foreach (var msg in _detail.Conversation)
                {
                    <div class="log-line @(msg.Role == "assistant" ? "log-info" : "log-debug")">
                        <strong>[@msg.Role]</strong> @msg.Content
                    </div>
                }
            </div>
        </details>
    }

    @if (_detail.Status == GoalStatus.Draft || _detail.Status == GoalStatus.Failed)
    {
        <div style="margin-top:1.5rem">
            <button style="background:var(--red);color:#fff;border:none;padding:0.4rem 1rem;border-radius:4px;cursor:pointer;font-size:0.9rem"
                @onclick="DeleteCurrentGoal">🗑️ Delete Goal</button>
        </div>
    }
}
else if (_storedGoal is not null)
{
    <!-- Stored Goal (from SQLite — no active pipeline) -->
    <div class="card" style="margin-bottom:1rem">
        <div class="label">Description</div>
        <div class="chat-msg-content">@((MarkupString)RenderMarkdown(_storedGoal.Description))</div>
        <div style="margin-top:0.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <span class="badge @StatusBadge(_storedGoal.Status)">@_storedGoal.Status</span>
            <span style="color:var(--text-muted)">Priority: @_storedGoal.Priority</span>
            @if (_storedGoal.Iterations.HasValue)
            {
                <span style="color:var(--text-muted)">Iterations: <strong style="color:var(--text)">@_storedGoal.Iterations</strong></span>
            }
        </div>
        <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--text-muted)">
            Created: @_storedGoal.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC
            @if (_storedGoal.StartedAt.HasValue)
            {
                <span style="margin-left:1rem">Started: @_storedGoal.StartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            }
            @if (_storedGoal.CompletedAt.HasValue)
            {
                <span style="margin-left:1rem">Completed: @_storedGoal.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            }
        </div>
        @if (_storedGoal.TotalDurationSeconds.HasValue)
        {
            <div style="margin-top:0.25rem;font-size:0.8rem;color:var(--text-muted)">
                Total duration: @FormatTotalDuration(_storedGoal.TotalDurationSeconds.Value)
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_storedGoal.FailureReason))
    {
        <div class="failure-callout">
            <div class="label">Failure Reason</div>
            <div style="margin-top:0.25rem">@_storedGoal.FailureReason</div>
        </div>
    }

    @if (_storedGoal.Notes.Count > 0)
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label">Notes</div>
            <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.85rem">
                @foreach (var note in _storedGoal.Notes)
                {
                    <li style="color:var(--text-muted)">@note</li>
                }
            </ul>
        </div>
    }

    @if (_storedGoal.PhaseDurations is { Count: > 0 })
    {
        <div class="card" style="margin-bottom:1rem">
            <div class="label">Phase Durations</div>
            <table style="margin-top:0.5rem;max-width:400px">
                <thead><tr><th>Phase</th><th>Duration</th></tr></thead>
                <tbody>
                    @foreach (var kvp in _storedGoal.PhaseDurations)
                    {
                        <tr>
                            <td>@kvp.Key</td>
                            <td style="color:var(--text-muted)">@FormatDuration(kvp.Value)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- SQLite Iteration History -->
    @if (_storedIterations.Count > 0)
    {
        <h2 style="margin-top:1.5rem">Iterations</h2>
        @foreach (var iter in _storedIterations)
        {
            <div class="iteration-section">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem">
                    <strong>Iteration @iter.Iteration</strong>
                    @if (!string.IsNullOrEmpty(iter.ReviewVerdict))
                    {
                        <span class="badge @ReviewBadge(iter.ReviewVerdict)">@iter.ReviewVerdict</span>
                    }
                </div>

                @if (iter.Phases.Count > 0)
                {
                    <div class="phase-bar" style="margin-bottom:0.5rem">
                        @foreach (var phase in iter.Phases)
                        {
                            <span class="phase-box @(phase.Result == "pass" ? "completed" : phase.Result == "fail" ? "failed" : "skipped")">
                                <span class="phase-box-icon">@(phase.Result == "pass" ? "✓" : phase.Result == "fail" ? "✗" : "~")</span>
                                @phase.Name
                                @if (phase.DurationSeconds > 0)
                                {
                                    <span class="phase-box-duration">@FormatDuration(phase.DurationSeconds)</span>
                                }
                            </span>
                        }
                    </div>
                }

                @if (iter.TestCounts is { } tc)
                {
                    <div class="iter-summary-cards">
                        <div class="card">
                            <div class="label">Tests</div>
                            <div class="value">@tc.Total</div>
                        </div>
                        <div class="card">
                            <div class="label">Passed</div>
                            <div class="value" style="color:var(--green)">@tc.Passed</div>
                        </div>
                        @if (tc.Failed > 0)
                        {
                            <div class="card">
                                <div class="label">Failed</div>
                                <div class="value" style="color:var(--red)">@tc.Failed</div>
                            </div>
                        }
                    </div>
                }

                @if (iter.Notes.Count > 0)
                {
                    <ul style="margin:0 0 0.5rem 1.2rem;font-size:0.85rem">
                        @foreach (var note in iter.Notes)
                        {
                            <li style="color:var(--text-muted)">@note</li>
                        }
                    </ul>
                }
            </div>
        }
    }
    else
    {
        <p style="color:var(--text-muted);margin-top:1rem">No iteration history recorded.</p>
    }

    @if (_storedGoal.RepositoryNames.Count > 0)
    {
        <div class="card" style="margin-top:1rem">
            <div class="label">Repositories</div>
            <div class="goal-repos" style="margin-top:0.25rem">
                @foreach (var repo in _storedGoal.RepositoryNames)
                {
                    <span class="repo-tag">@repo</span>
                }
            </div>
        </div>
    }

    @if (_storedGoal.Status == GoalStatus.Draft || _storedGoal.Status == GoalStatus.Failed)
    {
        <div style="margin-top:1.5rem">
            <button style="background:var(--red);color:#fff;border:none;padding:0.4rem 1rem;border-radius:4px;cursor:pointer;font-size:0.9rem"
                @onclick="DeleteCurrentGoal">🗑️ Delete Goal</button>
        </div>
    }
}
else
{
    <p style="color:var(--text-muted)">Goal not found.</p>
}

@code {
    [Parameter] public string GoalId { get; set; } = "";

    private GoalDetailInfo? _detail;
    private Goal? _storedGoal;
    private IReadOnlyList<IterationSummary> _storedIterations = [];
    private IReadOnlyList<ProgressEntry> _progress = [];
    private string? _selectedPhase;

    protected override void OnInitialized()
    {
        Refresh();
        State.OnStateChanged += RefreshState;
    }

    protected override void OnParametersSet() => Refresh();

    private void Refresh()
    {
        _detail = State.GetGoalDetail(GoalId);
        _progress = State.GetProgressForGoal(GoalId);

        // Fallback: load from SQLite for completed/failed goals not in active pipelines
        if (_detail is null)
        {
            _storedGoal = GoalStore.GetGoalAsync(GoalId).GetAwaiter().GetResult();
            _storedIterations = _storedGoal is not null
                ? GoalStore.GetIterationsAsync(GoalId).GetAwaiter().GetResult()
                : [];
        }
        else
        {
            _storedGoal = null;
            _storedIterations = [];
        }
    }

    private void RefreshState() => InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private void TogglePhase(string phaseKey)
    {
        _selectedPhase = _selectedPhase == phaseKey ? null : phaseKey;
    }

    private static string StatusBadge(GoalStatus s) => s switch
    {
        GoalStatus.Completed => "badge-green",
        GoalStatus.Failed => "badge-red",
        GoalStatus.InProgress => "badge-blue",
        GoalStatus.Pending => "badge-yellow",
        GoalStatus.Draft => "badge-muted",
        _ => "badge-muted",
    };

    private static string PhaseBadge(string status) => status switch
    {
        "completed" => "badge-green",
        "failed" => "badge-red",
        "active" => "badge-blue",
        _ => "badge-muted",
    };

    private static string PhaseIcon(string status) => status switch
    {
        "completed" => "✓",
        "failed" => "✗",
        "active" => "●",
        "pending" => "○",
        "skipped" => "~",
        _ => "○",
    };

    private static string ReviewBadge(string? verdict) =>
        string.Equals(verdict, "Approve", StringComparison.OrdinalIgnoreCase) ? "badge-green" : "badge-red";

    private static string FormatDuration(double seconds) =>
        seconds >= 60 ? $"{seconds / 60:F1}m" : $"{seconds:F0}s";

    private static string FormatTotalDuration(double seconds)
    {
        if (seconds >= 3600) return $"{seconds / 3600:F1}h";
        if (seconds >= 60) return $"{seconds / 60:F1}m";
        return $"{seconds:F0}s";
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static readonly MarkdownPipeline MdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static string RenderMarkdown(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return Markdown.ToHtml(content, MdPipeline);
    }

    public void Dispose() => State.OnStateChanged -= RefreshState;

    private async Task DeleteCurrentGoal()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete goal '{GoalId}'?");
        if (!confirmed) return;

        var response = await HttpClient.DeleteAsync($"/api/goals/{GoalId}");
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/goals");
        }
    }
}
