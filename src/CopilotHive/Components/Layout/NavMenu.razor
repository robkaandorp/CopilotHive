@using CopilotHive.Dashboard
@using CopilotHive.Orchestration
@implements IDisposable

<NavLink href="/" Match="NavLinkMatch.All">🏠 <span class="nav-label">Dashboard</span></NavLink>
<NavLink href="/composer">
    💬 <span class="nav-label">Composer
    @if (_pendingClarifications > 0)
    {
        <span class="badge badge-clarification" title="@_pendingClarifications pending clarification(s)">🔔 @_pendingClarifications</span>
    }
    </span>
</NavLink>
<NavLink href="/goals">🎯 <span class="nav-label">Goals</span></NavLink>
<NavLink href="/releases">📦 <span class="nav-label">Releases</span></NavLink>
<NavLink href="/orchestrator">🎵 <span class="nav-label">Orchestrator</span></NavLink>
<NavLink href="/workers">🐝 <span class="nav-label">Workers</span></NavLink>
<NavLink href="/configuration">⚙️ <span class="nav-label">Configuration</span></NavLink>
<NavLink href="/logs">🪵 <span class="nav-label">Logs</span></NavLink>

@code {
    [Inject] private DashboardStateService State { get; set; } = default!;
    [Inject] private ClarificationQueueService ClarificationQueue { get; set; } = default!;

    private int _pendingClarifications;

    protected override void OnInitialized()
    {
        _pendingClarifications = ClarificationQueue.PendingHumanCount;
        ClarificationQueue.OnChanged += HandleClarificationChanged;
    }

    private void HandleClarificationChanged()
    {
        InvokeAsync(() =>
        {
            _pendingClarifications = ClarificationQueue.PendingHumanCount;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ClarificationQueue.OnChanged -= HandleClarificationChanged;
    }
}
