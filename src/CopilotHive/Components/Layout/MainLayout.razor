@inherits LayoutComponentBase
@using CopilotHive.Orchestration
@inject CopilotHive.Dashboard.PageHeaderState PageHeader
@inject CopilotHive.Dashboard.DashboardStateService DashboardState
@inject CopilotHive.Orchestration.ClarificationQueueService ClarificationQueue
@implements IDisposable

<div class="hive-layout">
    <nav class="hive-nav">
        <div class="hive-brand">🐝 <span class="brand-text">CopilotHive</span></div>
        <NavMenu />
    </nav>
    <header class="hive-header" style="justify-content: flex-start;">
        @if (PageHeader.BackUrl is { } backUrl)
        {
            <a href="@backUrl" class="hive-header-back" title="Back">←</a>
        }
        <h1>@PageHeader.Title</h1>
        @if (_pendingClarificationCount > 0)
        {
            <button class="header-bell-btn" @onclick="OpenDrawer" title="Pending clarifications">
                🔔
                <span class="header-bell-badge">@_pendingClarificationCount</span>
            </button>
        }
    </header>

    @if (_drawerOpen)
    {
        <div class="clarification-drawer-backdrop" @onclick="CloseDrawer"></div>
    }
    <div class="clarification-drawer @(_drawerOpen ? "clarification-drawer-open" : "")" aria-hidden="@(!_drawerOpen)">
        <div class="clarification-drawer-header">
            <h3>📋 Clarifications (@_pendingClarifications.Count)</h3>
            <button class="chat-action-btn" @onclick="CloseDrawer">✕ Close</button>
        </div>
        <div class="clarification-drawer-body">
            @foreach (var req in _pendingClarifications)
            {
                <div class="clarification-item">
                    <div class="clarification-meta">
                        <span class="badge badge-muted">@req.GoalId</span>
                        <span class="badge badge-yellow">@req.WorkerRole</span>
                        <span class="text-muted">@req.RequestedAt.ToString("HH:mm:ss")</span>
                    </div>
                    <div class="clarification-question">@req.Question</div>
                    <div class="clarification-answer-area">
                        <textarea class="chat-input clarification-answer-input"
                                  @bind="_clarificationAnswers[req.Id]"
                                  placeholder="Type your answer…"
                                  rows="2"></textarea>
                        <button class="chat-send clarification-submit-btn"
                                disabled="@(string.IsNullOrWhiteSpace(GetClarificationAnswer(req.Id)))"
                                @onclick="() => SubmitClarificationAnswer(req.Id)">
                            Submit
                        </button>
                    </div>
                </div>
            }

            @if (_pendingClarifications.Count == 0)
            {
                <div class="text-muted" style="padding: 1rem;">No pending clarifications.</div>
            }
        </div>
    </div>
    <main class="hive-main">
        @Body
    </main>
    <footer class="hive-footer">
        <span class="nav-version-footer">
            <span class="badge @(_isBeta ? "badge-yellow" : "badge-muted")">v@(_version)</span>
        </span>
        <a href="https://github.com/robkaandorp/CopilotHive" target="_blank" rel="noopener noreferrer">CopilotHive on GitHub</a>
    </footer>
</div>

@code {
    private string _version = "";
    private bool _isBeta;
    private int _pendingClarificationCount;
    private List<ClarificationRequest> _pendingClarifications = [];
    private bool _drawerOpen;
    private readonly Dictionary<string, string> _clarificationAnswers = new();

    protected override void OnInitialized()
    {
        _version = DashboardState.GetVersion();
        _isBeta = _version.Contains("-beta", StringComparison.OrdinalIgnoreCase)
                  || _version.Contains("-alpha", StringComparison.OrdinalIgnoreCase)
                  || _version.Contains("-rc", StringComparison.OrdinalIgnoreCase)
                  || _version.StartsWith("0.");
        PageHeader.OnChanged += HandleTitleChanged;
        ClarificationQueue.OnChanged += HandleClarificationChanged;
        RefreshClarifications();
    }

    private void HandleClarificationChanged()
    {
        InvokeAsync(() =>
        {
            RefreshClarifications();
            StateHasChanged();
        });
    }

    private void RefreshClarifications()
    {
        _pendingClarifications = ClarificationQueue.GetPendingHumanRequests().ToList();
        _pendingClarificationCount = _pendingClarifications.Count;
        if (_pendingClarificationCount == 0) _drawerOpen = false;
        // Ensure answer inputs exist for all pending requests
        foreach (var req in _pendingClarifications)
        {
            _clarificationAnswers.TryAdd(req.Id, "");
        }
    }

    private void OpenDrawer()
    {
        _drawerOpen = true;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
    }

    private string GetClarificationAnswer(string requestId)
    {
        _clarificationAnswers.TryGetValue(requestId, out var answer);
        return answer ?? "";
    }

    private void SubmitClarificationAnswer(string requestId)
    {
        if (!_clarificationAnswers.TryGetValue(requestId, out var answer) ||
            string.IsNullOrWhiteSpace(answer))
            return;

        ClarificationQueue.SubmitAnswer(requestId, answer.Trim(), "human");
        _clarificationAnswers.Remove(requestId);
        RefreshClarifications();
        StateHasChanged();
    }

    private void HandleTitleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        PageHeader.OnChanged -= HandleTitleChanged;
        ClarificationQueue.OnChanged -= HandleClarificationChanged;
    }
}
